<https://doi.org/10.5281/zenodo.20512957>
        rdf:type               obo:T4FS_0000113;
        datacite:IsPartOf      <https://zenodo.org/communities/globias/> , <https://zenodo.org/communities/scads-ai/> , <https://zenodo.org/communities/nfdi4bioimage/>;
        datacite:IsVersionOf   <https://doi.org/10.5281/zenodo.20512956>;
        datacite:Issued        "2026-06-02"^^xs:date;
        datacite:Updated       "2026-06-02"^^xs:date;
        datacite:creator       orcid:0000-0001-5949-2327;
        datacite:description   "In  this presentation we learn  about the impact of generative artificial intelligence (AI), and in particular large language models (LLMs), on the field of bio image analysis. We dive deeper into data analysis code-generation and AI systems built around LLMs integrating code generation in our workflows conveniently:\n\n\n\nbia-bob\n\ngit-bob\n\nsand-bob\n\n\nFinally, we take a look at how these systems can be used on sovereign infrastructure to support privacy in a scientific context.";
        datacite:resourceType  "Presentation";
        datacite:right         "None" , "Creative Commons Attribution 4.0 International";
        datacite:title         "How Generative Artificial Intelligence impacts Bio-image Data Science" .

<https://doi.org/10.5281/zenodo.20509378>
        rdf:type               obo:T4FS_0000113;
