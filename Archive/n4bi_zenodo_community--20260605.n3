<https://doi.org/10.5281/zenodo.19107804>
        rdf:type               obo:T4FS_0000113;
        datacite:IsPartOf      <https://zenodo.org/communities/gerbi/> , <https://zenodo.org/communities/nfdi4bioimage/>;
