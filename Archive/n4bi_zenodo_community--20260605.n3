<https://doi.org/10.5281/zenodo.7015307>
        rdf:type               obo:T4FS_0000113;
        datacite:IsPartOf      <https://zenodo.org/communities/neubias/> , <https://zenodo.org/communities/nfdi4bioimage/>;
        datacite:IsVersionOf   <https://doi.org/10.5281/zenodo.7015306>;
