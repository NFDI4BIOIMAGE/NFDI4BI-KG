        datacite:creator         orcid:0000-0001-6113-3518 , orcid:0000-0001-6457-4853 , orcid:0000-0001-7545-2181 , orcid:0000-0002-1890-0192 , orcid:0000-0002-4316-078X , orcid:0000-0002-4790-7377 , orcid:0000-0002-5727-0226 , orcid:0000-0003-3328-6693 , orcid:0009-0004-2517-0791 , orcid:0009-0005-1140-3352 , orcid:0000-0001-8528-9023 , orcid:0000-0002-4392-8154 , orcid:0000-0003-4028-811X , orcid:0000-0001-7734-3771 , orcid:0000-0002-4382-5104 , orcid:0000-0001-8665-6382 , orcid:0000-0002-1481-2996 , orcid:0000-0003-3925-6778 , orcid:0000-0003-2370-3430;
        datacite:description     "The NFDI - German National Research Data Infrastructure - consortia DataPLANT, NFDI4Microbiota, NFDI4Biodiversity, FAIRagro, NFDI4Objects, and NFDI4BIOIMAGE agree on a close cooperation to align their activities and offerings regarding the management of biological data. The Memorandum of Understanding details the foci of the consortia and their areas of cooperation, and forms the foundation of the activities within the Biodata Interest Group.\n\nThe present document is an extended version of the MoU developed by DataPlant, NFDI4Biodiversity and NFDI4Microbiota in 2024 (see Förstner, K., Ebert, B., Glöckner, F.-O., von Suchodoletz, D., McHardy, A. C., & Mühlhaus, T. (2024). Memorandum of Understanding between NFDI4Biodiversity, NFDI4Microbiota and DataPlant. Zenodo. https://doi.org/10.5281/zenodo.13880944).";
        datacite:resourceType    "None";
        datacite:right           "None" , "Creative Commons Attribution 4.0 International";
        datacite:subject         "biodata" , "Memorandum of Understanding" , "research data management" , "NFDI";
        datacite:title           "Memorandum of Understanding between the NFDI consortia DataPLANT, NFDI4Microbiota, NFDI4Biodiversity, FAIRagro, NFDI4Objects, and NFDI4BIOIMAGE" .

