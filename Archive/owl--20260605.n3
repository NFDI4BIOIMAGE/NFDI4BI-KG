                           owl:onProperty      core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:ArcType;
                           owl:onProperty     core:type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:power
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:power
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:lot_number
                         ];
        skos:definition  "\nThe Arc element is used to describe various kinds of Arc lamps - Hg, Xe, HgXe.\nThe Power of the Arc is now stored in the LightSource.\n\nAttributes\n----------\ntype : None | Arc_Type\n    The type of Arc lamp.";
        skos:inScheme    core: .

nfdicore:NFDI_0001094
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "Dr. Dr."@en;
        skos:definition  "Two Doctor degrees (PhD or equivalent academic doctorate)"@en .

nfdicore:NFDI_0001093
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001056;
        rdfs:label       "test phase status"@en;
        skos:definition  "Test Phase Status is a status specification that indicates an entity, process, or project is undergoing testing, evaluation, or validation before finalization." .

nfdicore:NFDI_0001092
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001051;
        rdfs:label       "self funding"@en;
        skos:definition  "Self-Funding is a funding specification that defines the use of personal, internal, or independently generated financial resources to support activities, projects, or organizations without relying on external funding sources." .

nfdicore:NFDI_0001091
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001052;
        rdfs:label       "restricted access"@en;
        skos:definition  "Restricted Access is an information access specification that defines policies limiting access to specific users, organizations, or groups based on predefined criteria such as confidentiality, security, or legal regulations." .

nfdicore:NFDI_0001090
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001051;
        rdfs:label       "project funding"@en;
        skos:definition  "Project Funding is a funding specification that defines the financial mechanisms, grants, and investment strategies used to support specific research, development, or innovation projects." .

nfdicore:NFDI_0001089
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "Prof. Dr.-Ing."@en;
        skos:definition  "Professor with a doctorate in engineering." .

nfdicore:NFDI_0001088
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "Prof. Dr."@en;
        skos:definition  "Professor with a doctorate." .

nfdicore:NFDI_0001087
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "Prof."@en;
        skos:definition  "Professor (academic title for a senior faculty member)." .

nfdicore:NFDI_0001086
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001056;
        rdfs:label       "planning status"@en;
        skos:definition  "Planning Status is a status specification that indicates an entity, process, or project is in a preparatory or strategic development phase before execution." .

nfdicore:NFDI_0001085
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "PD. Dr. habil."@en;
        skos:definition  "Privatdozent with Habilitation (higher academic qualification in Germany)" .

nfdicore:NFDI_0001084
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "PD. Dr."@en;
        skos:definition  "Privatdozent (Dr. with habilitation, qualified to teach at a university)" .

nfdicore:NFDI_0001083
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001052;
        rdfs:label       "paywall access"@en;
        skos:definition  "Paywall Access is an information access specification that defines policies requiring users to purchase, subscribe, or obtain institutional licenses to access digital or physical information resources." .

nfdicore:NFDI_0001082
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001056;
        rdfs:label       "paused status"@en;
        skos:definition  "Paused Status is a status specification that indicates an entity, process, or project is temporarily halted but may resume at a later stage." .

nfdicore:NFDI_0001081
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001051;
        rdfs:label       "organizational funding"@en;
        skos:definition  "Organizational Funding is a funding specification that defines the financial structures, budgets, and resource allocation strategies for sustaining the operations of an organization or institution." .

nfdicore:NFDI_0001080
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001052;
        rdfs:label       "open access"@en;
        skos:definition  "Open Access is an information access specification that defines policies allowing unrestricted public access to information resources, ensuring free availability without subscription or payment barriers." .

nfdicore:NFDI_0001079
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001050;
        rdfs:label       "online implementation"@en;
        skos:definition  "Online Implementation is an event implementation specification that defines the organization of an event conducted entirely through virtual platforms, enabling remote participation via digital communication technologies." .

nfdicore:NFDI_0001078
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001050;
        rdfs:label       "on site implementation"@en;
        skos:definition  "On-Site Implementation is an event implementation specification that defines the organization of an event that occurs exclusively at a physical location with in-person attendance." .

nfdicore:NFDI_0001077
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "M.Sc."@en;
        skos:definition  "Master of Science (graduate degree in science/engineering)." .

nfdicore:NFDI_0001076
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001052;
        rdfs:label       "internal access"@en;
        skos:definition  "Internal Access is an information access specification that defines policies and mechanisms restricting access to information exclusively within an organization, institution, or research group." .

nfdicore:NFDI_0001075
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001050;
        rdfs:label       "hybrid implementation"@en;
        skos:definition  "Hybrid Implementation is an event implementation specification that defines the organization of an event that integrates both physical (on-site) and virtual (online) participation modes" .

nfdicore:NFDI_0001074
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001056;
        rdfs:label       "finished status"@en;
        skos:definition  "Finished Status is a status specification that indicates an entity, process, or project has successfully reached its intended goal and is considered complete." .

nfdicore:NFDI_0001073
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "Dr.-Ing."@en;
        skos:definition  "Doctor of Engineering (German doctorate in engineering)." .

nfdicore:NFDI_0001072
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001040;
        rdfs:label       "Dr."@en;
        skos:definition  "Doctor (PhD or equivalent academic doctorate)" .

nfdicore:NFDI_0001071
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001056;
        rdfs:label       "cancelled status"@en;
        skos:definition  "Cancelled Status is a status specification that indicates an entity, process, or project has been terminated before reaching completion due to internal or external factors." .

nfdicore:NFDI_0001070
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0001056;
        rdfs:label       "active status"@en;
        skos:definition  "Active Status is a status specification that indicates an entity, process, or project is currently operational, ongoing, or in execution." .

nfdicore:NFDI_0010041
        rdf:type         owl:Class;
        rdfs:label       "obsolete software script"@en;
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000595";
        obo:IAO_0100001  obo:IAO_0000595;
        owl:deprecated   true;
        skos:definition  "A software script is software whose instructions can be executed using a software interpreter." .

nfdicore:NFDI_0010040
        rdf:type         owl:Class;
        rdfs:label       "obsolete software module"@en;
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000592";
        obo:IAO_0100001  obo:IAO_0000592;
        owl:deprecated   true;
        skos:definition  "A software module is software composed of a collection of software methods." .

nfdicore:NFDI_0010039
        rdf:type         owl:Class;
        rdfs:label       "obsolete software method"@en;
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000591";
        obo:IAO_0100001  obo:IAO_0000591;
        owl:deprecated   true;
        skos:definition  "A software method (also called subroutine, subprogram, procedure, method, function, or routine) is software designed to execute a specific task." .

nfdicore:NFDI_0010038
        rdf:type         owl:Class;
        rdfs:label       "data visualization process"@en;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where data is represented visually through charts, graphs, or other formats to aid in understanding and decision-making." .

nfdicore:NFDI_0010037
        rdf:type         owl:Class;
        rdfs:label       "data storage process"@en;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where data is securely stored in databases or other systems, ensuring it can be retrieved and accessed as needed." .

nfdicore:NFDI_0010036
        rdf:type         owl:Class;
        rdfs:label       "data integration process"@en;
        rdfs:seeAlso     obo:T4FS_0000487;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where data from multiple sources are combined or merged to create a cohesive and comprehensive dataset for analysis." .

nfdicore:NFDI_0010035
        rdf:type         owl:Class;
        rdfs:label       "data transformation process"@en;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process involving the conversion of data into a different format, structure, or scale to make it compatible with analysis tools or systems." .

nfdicore:NFDI_0010034
        rdf:type         owl:Class;
        rdfs:label       "data cleaning process"@en;
        rdfs:seeAlso     obo:T4FS_0000384;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where incorrect, incomplete, or irrelevant data is identified and corrected or removed to improve the quality of the dataset." .

nfdicore:NFDI_0010033
        rdf:type         owl:Class;
        rdfs:label       "dataset documenting process"@en;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where metadata, descriptions, and details about datasets are recorded to ensure clarity, context, and proper usage by others." .

nfdicore:NFDI_0010031
        rdf:type         owl:Class;
        rdfs:label       "dataset creation process"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0010028
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:OBI_0000299;
                                                   owl:someValuesFrom  obo:IAO_0001000
                                                 ]
                                               )
                         ];
        skos:definition  "A data handling process involving the organization and structuring of data into datasets for easier access, analysis, and sharing." .

nfdicore:NFDI_0010030
        rdf:type         owl:Class;
        rdfs:label       "data processing process"@en;
        rdfs:seeAlso     obo:T4FS_0000044;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where raw data is cleaned, transformed, and analyzed to extract meaningful insights, patterns, or trends." .

nfdicore:NFDI_0010029
        rdf:type         owl:Class;
        rdfs:label       "data producing process"@en;
        rdfs:subClassOf  nfdicore:NFDI_0010028;
        skos:definition  "A data handling process where raw data is generated through experiments, observations, or data collection tools, often as the initial step in the data lifecycle." .

nfdicore:NFDI_0010028
        rdf:type         owl:Class;
        rdfs:label       "data handling process"@en;
        rdfs:seeAlso     obo:T4FS_0000012;
        rdfs:subClassOf  obo:BFO_0000015;
        skos:definition  "A process that involves the collection, organization, cleaning, analysis, storage, and sharing of data to ensure its accuracy, accessibility, and usefulness for decision-making, research, or other applications. Data handling encompasses all stages from raw data generation to its final visualization or publication." .

nfdicore:NFDI_0010027
        rdf:type         owl:Class;
        rdfs:label       "panel discussion"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event featuring a group of experts who share their insights and engage in a moderated discussion on a particular subject, followed by audience questions."@en .

nfdicore:NFDI_0010026
        rdf:type         owl:Class;
        rdfs:label       "symposium"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event where researchers and experts present and discuss their work, often centered around a specific theme or area of study."@en .

nfdicore:NFDI_0010025
        rdf:type         owl:Class;
        rdfs:label       "seminar"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event where a small group of participants discuss a specific topic in depth, often involving presentations and interactive discussions."@en .

nfdicore:NFDI_0010024
        rdf:type         owl:Class;
        rdfs:label       "summer school"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event held during the summer, providing specialized courses or workshops to supplement regular academic studies or offer additional learning opportunities."@en .

nfdicore:NFDI_0010023
        rdf:type         owl:Class;
        rdfs:label       "course"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event structured as a program of study, offering instruction on a particular subject, often leading to certification or academic credit."@en .

nfdicore:NFDI_0010022
        rdf:type         owl:Class;
        rdfs:label       "lecture"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event where a subject matter expert delivers a formal presentation to inform or educate an audience about a specific topic."@en .

nfdicore:NFDI_0010021
        rdf:type         owl:Class;
        rdfs:label       "hackathon"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event where participants collaborate intensively over a short period to develop technological solutions, such as software or hardware projects."@en .

nfdicore:NFDI_0010020
        rdf:type         owl:Class;
        rdfs:label       "conference"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event where experts and scholars gather to present research, exchange ideas, and discuss advancements in a particular field."@en .

nfdicore:NFDI_0010019
        rdf:type         owl:Class;
        rdfs:label       "workshop"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "An event focused on interactive learning, where participants engage in hands-on activities or group work to develop specific skills or knowledge."@en .

nfdicore:NFDI_0010018
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "construction engineering"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the planning, design, and management of construction projects, including buildings, infrastructure, and other structures. Construction engineering integrates principles of civil engineering, project management, and materials science to ensure safety, efficiency, and sustainability in construction processes."@en .

nfdicore:NFDI_0010016
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "materials science"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that explores the properties, performance, and applications of materials, focusing on the relationship between a material's structure and its characteristics. Materials science and engineering involves the design, development, and testing of materials for use in a wide range of industries, including aerospace, electronics, and manufacturing."@en .

nfdicore:NFDI_0010014
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "mechanical engineering"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the design, analysis, manufacturing, and maintenance of mechanical systems. Mechanical engineering applies principles of physics, materials science, and mathematics to develop machines, tools, and devices used in industries such as transportation, energy, and robotics."@en .

nfdicore:NFDI_0010012
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "geoscience"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the study of the Earth’s structure, processes, and materials, including the atmosphere, oceans, and landforms. Geoscience encompasses fields such as geology, meteorology, and environmental science to understand Earth’s history, natural resources, and natural hazards."@en .

nfdicore:NFDI_0010011
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "mathematics"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that involves the study of numbers, quantities, shapes, and patterns, using abstract concepts and logical reasoning. Mathematics is fundamental to various fields, including science, engineering, economics, and technology, providing tools for problem-solving, analysis, and modeling." .

nfdicore:NFDI_0010010
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "physics"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that explores the fundamental principles governing the behavior of matter, energy, and the forces of nature. Physics seeks to understand the laws of the universe, from subatomic particles to cosmic phenomena, through experimentation, observation, and mathematical modeling."@en .

nfdicore:NFDI_0010008
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "chemistry"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that studies the composition, structure, properties, and reactions of matter. Chemistry focuses on understanding how substances interact, transform, and combine to form new materials, playing a crucial role in fields such as medicine, energy, and environmental science."@en .

nfdicore:NFDI_0010007
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "natural science"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that studies the natural world through observation, experimentation, and analysis. Natural science includes fields such as physics, chemistry, biology, and earth sciences, aiming to understand the laws and processes governing the universe and life on Earth." .

nfdicore:NFDI_0010006
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "agriculture"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the science, practice, and business of cultivating plants, raising animals, and producing food, fiber, and other products. Agriculture involves the study of soil management, crop production, livestock care, and sustainable farming practices to ensure food security and environmental sustainability."@en .

nfdicore:NFDI_0010005
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "medicine"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the science and practice of diagnosing, treating, and preventing illnesses and injuries. Medicine involves the study of human health, medical technologies, pharmaceuticals, and patient care to improve well-being and extend life."@en .

nfdicore:NFDI_0010004
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "biology"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that studies living organisms, their structures, functions, growth, and interactions with their environment. Biology explores the diversity of life, from microscopic organisms to complex ecosystems, and seeks to understand the underlying processes of life, evolution, and heredity."@en .

nfdicore:NFDI_0010002
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "social science"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that studies society and human behavior through disciplines like sociology, psychology, and economics."@en .

nfdicore:NFDI_0010001
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "humanity"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline focused on human culture, thought, and creativity, encompassing disciplines like literature, philosophy, and the arts."@en .

nfdicore:NFDI_0001067
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "cybersecurity"@en;
        obo:IAO_0000119  "Stallings, W. (2020). Network Security Essentials. Pearson.";
        skos:broader     nfdicore:NFDI_0010017;
        skos:definition  "Cybersecurity is a sub-discipline of Computer Science that focuses on protecting computer systems, networks, and data from cyber threats, vulnerabilities, and unauthorized access.";
        skos:example     "Encryption techniques, intrusion detection systems, and ethical hacking studies belong to Cybersecurity." .

nfdicore:NFDI_0001066
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "data science"@en;
        obo:IAO_0000119  "Provost, F., & Fawcett, T. (2013). Data Science for Business. O'Reilly Media.";
        skos:broader     nfdicore:NFDI_0010017;
        skos:definition  "Data Science is a sub-discipline of Computer Science that integrates statistical methods, machine learning, and data processing techniques to extract insights and knowledge from structured and unstructured data.";
        skos:example     "Predictive analytics, big data visualization, and recommendation systems are part of Data Science." .

nfdicore:NFDI_0001065
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "software engineering"@en;
        skos:broader     nfdicore:NFDI_0010017;
        skos:definition  "Software Engineering is a sub-discipline of Computer Science that applies engineering principles to the design, development, testing, and maintenance of software systems.";
        skos:example     "Agile software development, DevOps practices, and software architecture design fall under Software Engineering." .

nfdicore:NFDI_0001064
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "theoretical computer science"@en;
        skos:broader     nfdicore:NFDI_0010017;
        skos:definition  "Theoretical Computer Science is a sub-discipline of Computer Science that focuses on mathematical models of computation, computational complexity, and algorithmic problem-solving";
        skos:example     "Studies on Turing machines, complexity classes (P vs NP), and formal languages belong to Theoretical Computer Science." .

nfdicore:NFDI_0010017
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "computer science"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the study of algorithms, data structures, programming, and computational systems. Computer science explores how to design, develop, and analyze software and hardware solutions to solve complex problems and advance technology."@en .

nfdicore:NFDI_0001063
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "artificial intelligence"@en;
        obo:IAO_0000119  "Russell, S., & Norvig, P. (2020). Artificial Intelligence: A Modern Approach. Pearson.";
        skos:broader     nfdicore:NFDI_0010017;
        skos:definition  "Artificial Intelligence (AI) is a sub-discipline of Computer Science that focuses on creating systems capable of performing tasks that require human-like intelligence, such as learning, reasoning, and problem-solving.";
        skos:example     "Deep learning for image recognition, reinforcement learning in robotics, and natural language processing fall under Artificial Intelligence." .

nfdicore:NFDI_0001062
        rdf:type         owl:Class;
        rdfs:label       "speaker role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000081;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000004
                                                 ]
                                               )
                         ];
        skos:definition  "A role inherent in an agent that is realized when delivers presentations, lectures, or speeches at events, conferences, or public gatherings."@en;
        skos:example     "invited speakers at scientific symposiums, keynote presenters at technology expos, and guest lecturers at universities" .

nfdicore:NFDI_0001061
        rdf:type         owl:Class;
        rdfs:label       "organizer role"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000229;
        skos:definition  "A role inherent in an agent that is realized when being responsible for planning, managing, and executing an event, project, or structured activity."@en;
        skos:example     "event management firms organizing scientific symposiums or non-profit organizations coordinating community outreach programs" .

nfdicore:NFDI_0001060
        rdf:type         owl:Class;
        rdfs:label       "manufacturer role"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000229;
        skos:definition  "A role inherent in an agent that is realized when being responsible for producing goods, components, or materials through industrial or commercial processes."@en;
        skos:example     "Siemens as a manufacturer of industrial automation equipment or Intel as a manufacturer of semiconductor chips" .

nfdicore:NFDI_0001059
        rdf:type         owl:Class;
        rdfs:label       "collaboration partner role"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000229;
        skos:definition  "A role inherent in an agent that is realized when engageing in cooperative work with another individual or organization toward a shared goal, such as research, development, or business initiatives."@en .

nfdicore:NFDI_0001058
        rdf:type         owl:Class;
        rdfs:label       "co spokesperson role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000081;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000004
                                                 ]
                                               )
                         ];
        skos:definition  "A role inherent in an agent that is realized when shareing the responsibilities of representing an organization, group, or initiative, typically communicating its views, policies, or findings to the public."@en .

nfdicore:NFDI_0001057
        rdf:type         owl:Class;
        rdfs:label       "co organizer role"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000229;
        skos:definition  "A role inherent in an agent that is realized when collaborating in planning, managing, and executing an event, project, or initiative alongside one or more primary organizers."@en .

nfdicore:NFDI_0001056
        rdf:type            owl:Class;
        rdfs:label          "status specification"@en;
        rdfs:subClassOf     obo:OBI_0001930;
        skos:definition     "A status specification is a directive information entity that defines the current state, progress, or condition of an entity, process, or project based on predefined criteria and operational guidelines.";
        skos:editorialNote  "HBN: Concerning the content of ‘Service’ and 'International collabrations' datasheets and their related knowledge graphs, the ‘Status Specification’ class and its instances were created to respond to competency questions like: what is the current status of a service or collaboration project, which collabrations are in an active state, etc." .

nfdicore:NFDI_0001054
        rdf:type               owl:Class;
        rdfs:label             "obsolete metadata specification"@en;
        owl:deprecated         true;
        skos:definition        "A Metadata Specification is a detailed document that describes metadata structures, guidelines, and usage policies for standardization and adoption.";
        skos:example           "metadata schema and standards";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/132\nhttps://github.com/ISE-FIZKarlsruhe/nfdicore/issues/133" .

nfdicore:NFDI_0001052
        rdf:type            owl:Class;
        rdfs:label          "information access specification"@en;
        rdfs:subClassOf     obo:OBI_0001930;
        skos:definition     "An information access specification is a directive information entity that defines the policies, conditions, and mechanisms governing the accessibility of digital or physical information resources for users or organizations.";
        skos:editorialNote  "HBN: Concerning the content of ‘Publication’ datasheet and its related knowledge graph, the ‘Information Access Specification’ class and its instances were created to respond to competency questions like: what access policies apply to a specific publication document, which resources are available under open access, etc." .

nfdicore:NFDI_0001051
        rdf:type            owl:Class;
        rdfs:label          "funding specification"@en;
        rdfs:subClassOf     obo:OBI_0001930;
        skos:definition     "A funding specification is a directive information entity that provides structured guidelines, policies, and requirements for securing, managing, and allocating financial resources for various activities, projects, or organizations.";
        skos:editorialNote  "HBN: Concerning the content of ‘Service’ datasheets and its related knowledge graph, the ‘Funding Specification’ class and its instances were created to respond to competency questions like what funding models exist for a given service." .

nfdicore:NFDI_0001050
        rdf:type            owl:Class;
        rdfs:label          "event implementation specification"@en;
        rdfs:subClassOf     [ rdf:type            owl:Class;
                              owl:intersectionOf  ( obo:OBI_0001930
                                                    [ rdf:type            owl:Restriction;
                                                      owl:onProperty      obo:IAO_0000219;
                                                      owl:someValuesFrom  nfdicore:NFDI_0000131
                                                    ]
                                                  )
                            ];
        skos:definition     "An event implementation specification is a type of Directive Information Entity that provides formal guidelines, constraints, and details on how an event should be executed. It specifies the mode of implementation, including logistical, technical, and procedural aspects required to carry out an event successfully.";
        skos:editorialNote  "HBN: Concerning the content of ‘Event’ datasheets and its related knowledge graph, the ‘Event Implementation Specification’ class and its instances were created to respond to competency questions like what are the implementation formats of a given event.";
        skos:example        "Specifications for organizing conferences, training workshops, and academic seminars in different formats such as virtual, in-person, or hybrid settings." .

nfdicore:NFDI_0001049
        rdf:type         owl:Class;
        rdfs:label       "workflow management software"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        skos:definition  "Workflow Management Software is a subclass of Software that provides tools for designing, automating, executing, and monitoring scientific or computational workflows in research and engineering domains." .

nfdicore:NFDI_0001048
        rdf:type         owl:Class;
        rdfs:label       "simulation software"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        skos:definition  "Simulation Software is a subclass of Software that facilitates the modeling and numerical simulation of physical, chemical, or computational systems to study behaviors, interactions, and performance under different conditions";
        skos:example     "Examples include COMSOL Multiphysics, LAMMPS, Quantum ESPRESSO, and ANSYS." .

nfdicore:NFDI_0001047
        rdf:type            owl:Class;
        rdfs:label          "operating system"@en;
        rdfs:subClassOf     obo:IAO_0000010;
        skos:definition     "An Operating System (OS) is a software system that manages computer hardware and software resources and provides common services for computer programs. It acts as an intermediary between users and the computer hardware, enabling the execution of application programs.";
        skos:editorialNote  "Concerning the content of ‘Software’ datasheet and its related knowledge graph, the ‘Operating System’ class wase created to respond to competency questions like what operating systems are compatible with a specific software.";
        skos:example        "Windows, Linux, MacOS" .

nfdicore:NFDI_0001046
        rdf:type         owl:Class;
        rdfs:label       "image processing software"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        skos:definition  "Image Processing Software is a subclass of Software that enables the manipulation, enhancement, analysis, and visualization of images obtained from experimental, computational, or simulation-based sources." .

nfdicore:NFDI_0001045
        rdf:type         owl:Class;
        rdfs:label       "electronic lab notebook"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        skos:definition  "An Electronic Lab Notebook (ELN) is a subclass of Software that provides a digital platform for recording, managing, and sharing experimental procedures, observations, and research data in scientific workflows." .

nfdicore:NFDI_0001044
        rdf:type         owl:Class;
        rdfs:label       "data analysis software"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        skos:definition  "Data Analysis Software is a subclass of Software designed to process, visualize, and interpret structured and unstructured data using statistical, machine learning, and computational techniques." .

nfdicore:NFDI_0001043
        rdf:type         owl:Class;
        rdfs:label       "meeting"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000018;
        skos:definition  "Av event that brings together individuals or groups for structured discussions, decision-making, planning, or coordination of research, educational, or institutional activities." .

nfdicore:NFDI_0001042
        rdf:type          owl:Class;
        rdfs:isDefinedBy  "http://purl.obolibrary.org/obo/IAO_0000648";
        rdfs:label        "zone improvement plan code"@en;
        rdfs:subClassOf   nfdicore:NFDI_0001041;
        skos:definition   "A postal code that is used in the United States for the purpose of sorting and delivering mail, and that denotes some postal delivery route or some aggregate of postal delivery routes." .

nfdicore:NFDI_0001041
        rdf:type          owl:Class;
        rdfs:isDefinedBy  "http://purl.obolibrary.org/obo/IAO_0000646";
        rdfs:label        "postal code"@en;
        rdfs:subClassOf   obo:IAO_0020000;
        skos:definition   "An identifier that denotes some postal delivery route, some aggregate of postal delivery routes or a geographical region and was created for the purpose of sorting and delivering mail." .

nfdicore:NFDI_0001040
        rdf:type         owl:Class;
        rdfs:label       "academic title"@en;
        rdfs:subClassOf  obo:IAO_0020000;
        skos:definition  "An academic title is an identifier that denotes an individual’s academic rank, qualification, or honorary designation within educational and research institutions.";
        skos:example     "Professor, Associate Professor, Dr., PhD, Dr. Ing." .

nfdicore:NFDI_0001037
        rdf:type         owl:Class;
        rdfs:label       "digital object identifier"@en;
        rdfs:subClassOf  obo:IAO_0000578;
        obo:IAO_0000118  "DOI";
        skos:definition  "A Digital Object Identifier (DOI) is a centrally registered identifier that provides a unique, persistent reference to digital objects such as publications, datasets, and software, ensuring reliable access and citation.";
        skos:example     "10.1016/j.compind.2023.104016" .

nfdicore:NFDI_0001036
        rdf:type         owl:Class;
        rdfs:label       "comment textual entity"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        skos:definition  "A comment textual entity is a textual entity that provides supplimentary information, feedback, opinions, clarifications, or annotations related to a specific subject.";
        skos:example     "peer review comments on journal articles, user feedback on digital repositories, inline annotations in collaborative documents, explanatory remarks in software code documentation" .

nfdicore:NFDI_0001035
        rdf:type         owl:Class;
        rdfs:label       "work package textual entity"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        skos:definition  "A work package textual entity is a textual entity that describes a structured unit of work within a project, outlining specific tasks, objectives, deliverables, and assigned responsibilities to achieve defined project outcomes." .

nfdicore:NFDI_0001033
        rdf:type          owl:Class;
        rdfs:isDefinedBy  "http://purl.obolibrary.org/obo/IAO_0000322";
        rdfs:label        "institution list"@en;
        rdfs:subClassOf   nfdicore:NFDI_0001029;
        skos:definition   "A part of a document that has parts that are institution identifications associated with the authors of the document" .

nfdicore:NFDI_0001032
        rdf:type         owl:Class;
        rdfs:label       "creator list"@en;
        rdfs:subClassOf  nfdicore:NFDI_0001029;
        skos:definition  "A part of a document that enumerates the creators of the document" .

nfdicore:NFDI_0001031
        rdf:type         owl:Class;
        rdfs:label       "contributor list"@en;
        rdfs:subClassOf  nfdicore:NFDI_0001029;
        skos:definition  "A part of a document that enumerates the contributors of the document" .

nfdicore:NFDI_0001030
        rdf:type          owl:Class;
        rdfs:isDefinedBy  "http://purl.obolibrary.org/obo/IAO_0000321";
        rdfs:label        "author list"@en;
        rdfs:subClassOf   nfdicore:NFDI_0001029;
        skos:definition   "A part of a document that enumerates the authors of the document" .

nfdicore:NFDI_0001029
        rdf:type          owl:Class;
        rdfs:isDefinedBy  "http://purl.obolibrary.org/obo/IAO_0000314";
        rdfs:label        "document part"@en;
        rdfs:subClassOf   obo:IAO_0000030;
        skos:definition   "An information content entity that is part of a document.";
        skos:example      "An abstract, introduction, method or results section." .

nfdicore:NFDI_0001022
        rdf:type         owl:Class;
        rdfs:label       "ontology namespace"@en;
        rdfs:subClassOf  obo:IAO_0000027;
        skos:definition  "A namespace refers to a distinct, unique identifier that is used to distinguish concepts and entities within an ontology from those in other ontologies or systems. It's typically represented as a URL or URI (Uniform Resource Identifier) and ensures that each element within the ontology has a globally unique reference."@en .

nfdicore:NFDI_0001021
        rdf:type         owl:Class;
        rdfs:label       "act of dissolution"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000131
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000057;
                                                   owl:someValuesFrom  obo:OBI_0000245
                                                 ]
                                               )
                         ];
        skos:definition  "The act of dissolution refers to a formal legal or administrative event that officially terminates or dissolves an entity, relationship, or agreement."@en .

nfdicore:NFDI_0001020
        rdf:type         owl:Class;
        rdfs:label       "act of foundation"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000131
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000057;
                                                   owl:someValuesFrom  obo:OBI_0000245
                                                 ]
                                               )
                         ];
        skos:definition  "The act of foundation refers to the formal establishment or creation of an institution, organization, or entity, typically through a legal, administrative, or ceremonial process."@en .

nfdicore:NFDI_0001019
        rdf:type         owl:Class;
        rdfs:label       "title"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        skos:definition  "A textual entity that denotes some resource."@en .

nfdicore:NFDI_0001018
        rdf:type         owl:Class;
        rdfs:label       "textual description"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        skos:definition  "A textual entity that describe some resource."@en .

nfdicore:NFDI_0001017
        rdf:type         owl:Class;
        rdfs:label       "export format specification"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:IAO_0000033
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:BFO_0000051;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000148
                                                 ]
                                               )
                         ];
        skos:definition  "A directive information entity that defines the structural, syntactic, and encoding rules for representing data when it is exported from a system."@en .

nfdicore:NFDI_0001016
        rdf:type               owl:Class;
        rdfs:label             "RISM identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "Répertoire International des Sources Musicales"@fr;
        obo:IAO_0000119        "https://rism.info/";
        skos:definition        "RISM (Répertoire International des Sources Musicales) is an international catalog of historical music sources, including manuscripts, printed music, and treatises. It provides unique identifiers and bibliographic data to support music research and documentation."@en;
        skos:example           "https://rism.online/sources/201001959/";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61";
        nfdicore:NFDI_0010015  "RISM"@en .

nfdicore:NFDI_0001015
        rdf:type               owl:Class;
        rdfs:label             "FactGrid identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "FactGrid"@en;
        obo:IAO_0000119        "https://database.factgrid.de/";
        skos:definition        "FactGrid is a collaborative, structured knowledge database designed for historical research. It operates on Wikibase and focuses on documenting historical entities, events, and relationships."@en;
        skos:example           "https://database.factgrid.de/entity/Q595";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61" .

nfdicore:NFDI_0001014
        rdf:type               owl:Class;
        rdfs:label             "ISIL identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "International Standard Identifier for Libraries and Related Organizations"@en;
        obo:IAO_0000119        "https://sigel.staatsbibliothek-berlin.de/";
        skos:definition        "ISIL (International Standard Identifier for Libraries and Related Organizations) is a globally recognized identifier system used to uniquely identify libraries, archives, museums, and other cultural institutions. It facilitates resource sharing, cataloging, and data exchange across institutions and countries."@en;
        skos:example           "https://ld.zdb-services.de/resource/organisations/DE-4153";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61";
        nfdicore:NFDI_0010015  "ISIL"@en .

nfdicore:NFDI_0001013
        rdf:type               owl:Class;
        rdfs:label             "ROR identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000119        "https://ror.org/";
        skos:definition        "ROR (Research Organization Registry) is a global, open, and community-driven registry of research organizations. It provides unique identifiers for institutions involved in research, enabling better data integration, disambiguation, and interoperability across scholarly communication systems."@en;
        skos:example           "https://ror.org/01kdxra28";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61";
        nfdicore:NFDI_0010015  "ROR"@en .

nfdicore:NFDI_0001012
        rdf:type               owl:Class;
        rdfs:label             "Wikidata identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "Wikidata"@en;
        obo:IAO_0000119        "https://www.wikidata.org/";
        skos:definition        "Wikidata is maintained by the Wikimedia Foundation and serves as a central repository for structured data used by Wikipedia, Wikimedia projects, and external applications."@en;
        skos:example           "https://www.wikidata.org/wiki/Q1388737";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61" .

nfdicore:NFDI_0001011
        rdf:type               owl:Class;
        rdfs:label             "GeoNames identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "GeoNames"@en;
        obo:IAO_0000119        "https://www.geonames.org/";
        skos:definition        "GeoNames is a geographical database that provides information on places, including names, coordinates, and administrative divisions. It integrates data from multiple sources and is widely used for geolocation, mapping, and geographic information systems (GIS)."@en;
        skos:example           "https://www.geonames.org/2950159";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61" .

nfdicore:NFDI_0001010
        rdf:type               owl:Class;
        rdfs:label             "VIAF identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "Virtual International Authority File"@en , "Integrated Authority File"@en;
        obo:IAO_0000119        "https://viaf.org/en";
        skos:definition        "The centrally registered identifier VIAF (Virtual International Authority File) is an international authority file that links and integrates authority records from multiple national libraries and other organizations. It provides a unique identifier for authors, creators, and entities, facilitating better data sharing and cataloging across institutions."@en;
        skos:example           "https://viaf.org/en/viaf/137346469";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61";
        nfdicore:NFDI_0010015  "VIAF"@en .

nfdicore:NFDI_0001009
        rdf:type               owl:Class;
        rdfs:label             "GND identifier"@en;
        rdfs:subClassOf        obo:IAO_0000578;
        obo:IAO_0000118        "Integrated Authority File"@en , "Gemeinsame Normdatei"@de;
        obo:IAO_0000119        "https://www.dnb.de/EN/Professionell/Standardisierung/GND/gnd_node.html";
        skos:definition        "A centrally registered identifier that is issued by the German National Library. The Integrated Authority File (GND) is facilitates the collaborative use and administration of authority data. These authority data represent and describe entities, i.e. persons, corporate bodies, conferences and events, geographic entities, topics and works relating to cultural and academic collections."@en;
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/61";
        nfdicore:NFDI_0010015  "GND"@en .

nfdicore:NFDI_0001004
        rdf:type         owl:Class;
        rdfs:label       "project proposal"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:IAO_0000310
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:IAO_0000136;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000002
                                                 ]
                                               )
                         ];
        skos:definition  "A project proposal is a detailed document that outlines the objectives, scope, requirements, and deliverables of a project. It serves as a blueprint for all stakeholders, ensuring everyone understands what needs to be accomplished."@en .

nfdicore:NFDI_0001001
        rdf:type         owl:Class;
        rdfs:label       "citation"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000301";
        skos:definition  "A textual entity intended to identify a particular publication." .

nfdicore:NFDI_0001000
        rdf:type         owl:Class;
        rdfs:label       "software title"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0001019
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:IAO_0000219;
                                                   owl:someValuesFrom  obo:IAO_0000010
                                                 ]
                                               )
                         ];
        skos:definition  "A textual entity that uniquely identifies a specific software application, program, or system, often used for branding, categorization, and reference in documentation, licensing, and distribution." .

nfdicore:NFDI_0000244
        rdf:type         owl:Class;
        rdfs:label       "service specification"@en;
        rdfs:subClassOf  obo:IAO_0000104;
        skos:definition  "A plan specification that defines the requirements, features, and parameters of a service, outlining its scope, performance, and delivery criteria."@en .

nfdicore:NFDI_0000230
        rdf:type         owl:Class;
        rdfs:label       "service provider role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:BFO_0000054;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000101
                                                 ]
                                               )
                         ];
        skos:definition  "A role inherent in an agent that is realized when delivering services, managing processes, and ensuring the effective fulfillment of service product requirements."@en .

nfdicore:NFDI_0000228
        rdf:type         owl:Class;
        rdfs:label       "service product role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:BFO_0000023
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:BFO_0000054;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000101
                                                 ]
                                               )
                         ];
        skos:definition  "Role of an immaterial entity that facilitates the delivery or support of a service product, ensuring its proper execution and value realization."@en .

nfdicore:NFDI_0000222
        rdf:type         owl:Class;
        rdfs:label       "web application software"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        skos:definition  "Software that is installed on a server and can be used by users via a web page and the internet, for example Software-as-a-service (SaaS)."@en .

nfdicore:NFDI_0000219
        rdf:type         owl:Class;
        rdfs:label       "training service"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000101;
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        skos:definition  "Standalone training for self-study can be considered a technical service (usually a web application). Generally speaking, training materials often come in the form of specific measures or tutorials that are attached to a service and that are designed to improve the user’s service experience. Our joint understanding of training as a stand-alone service, however, is not limited to the above and includes materials designed for education in all fields of research data management."@en .

nfdicore:NFDI_0000218
        rdf:type         owl:Class;
        rdfs:label       "obsolete software application"@en;
        rdfs:seeAlso     "http://purl.obolibrary.org/obo/IAO_0000594";
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        obo:IAO_0100001  obo:IAO_0000594;
        owl:deprecated   true;
        skos:definition  "Software that can be downloaded and executed locally on the users' hardware."@en .

nfdicore:NFDI_0000214
        rdf:type         owl:Class;
        rdfs:label       "support service"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000101;
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        skos:definition  "Service with direct user contact for topics going beyond the support for specific single services."@en .

nfdicore:NFDI_0000210
        rdf:type         owl:Class;
        rdfs:label       "storage service"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000101;
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        skos:definition  "Provision of storage space for research data as a service to external users. Access is possible via web protocols."@en .

nfdicore:NFDI_0000203
        rdf:type               owl:Class;
        rdfs:label             "obsolete specification"@en;
        owl:deprecated         true;
        skos:definition        "A directive information entity that defines the requirements, characteristics, or standards for the design, implementation, or operation of a system, product, or process.Specification is a set of requirements, guidelines, standards contributed by an organization or a person."@en;
        skos:editorialNote     "2024-03-24. Sasha Bruns: specifications have dual nature - they are both directive information entities guiding actions (plan specification) and digital intellectual resources providing relevant information and guidelines (creative work)."@en;
        skos:example           "Guidelines, technical specifications, design specifications"@en;
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/133" .

nfdicore:NFDI_0000190
        rdf:type            owl:Class;
        rdfs:label          "obsolete publication"@en;
        obo:IAO_0100001     obo:IAO_0000311;
        owl:deprecated      true;
        skos:definition     "A publication that is the output of a publishing process and a creative process."@en;
        skos:editorialNote  "A published scholarly work that reports on ongoing activity about or within a resource, e.g. a dataset."@en;
        skos:example        "MusiXplora: Visual analysis of a musicological encyclopedia, Textkategorien in kompositorischen Werkstattdokumenten" .

nfdicore:NFDI_0000159
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "process engineering"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the design, optimization, and operation of industrial processes to transform raw materials into valuable products. Process engineering applies principles of chemistry, physics, and engineering to improve efficiency, sustainability, and safety in industries such as manufacturing, energy, and pharmaceuticals."@en .

nfdicore:NFDI_0000157
        rdf:type         owl:NamedIndividual , nfdicore:NFDI_0000100;
        rdfs:label       "electrical engineering"@en;
        rdfs:seeAlso     "https://www.dfg.de/en/research-funding/proposal-funding-process/interdisciplinarity/subject-area-structure";
        skos:definition  "An academic discipline that focuses on the study, design, and application of electrical systems and technologies. Electrical engineering involves the development of devices, circuits, and systems for power generation, communication, electronics, and automation." .

nfdicore:NFDI_0000148
        rdf:type               owl:Class;
        rdfs:label             "MIME-type"@en;
        rdfs:seeAlso           "https://www.iana.org/assignments/media-types/media-types.xhtml";
        rdfs:subClassOf        nfdicore:NFDI_0000145;
        skos:definition        "A media type that serves as a standardized identifier for specifying the nature and format of data."@en;
        skos:editorialNote     "The MIME-type template of the resource"@en;
        skos:example           "https://www.iana.org/assignments/media-types/application/dicom, https://www.iana.org/assignments/media-types/video/mp4, https://www.iana.org/assignments/media-types/text/n3"@en;
        nfdicore:NFDI_0000012  "MIMEType" .

nfdicore:NFDI_0000140
        rdf:type         owl:Class;
        rdfs:label       "obsolete software library"@en;
        rdfs:seeAlso     "http://purl.obolibrary.org/obo/IAO_0000593";
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        obo:IAO_0100001  obo:IAO_0000593;
        owl:deprecated   true;
        skos:definition  "Collection of pre-implemented functions for a specific task that can be accessed via a well-defined interface."@en .

nfdicore:NFDI_0000134
        rdf:type            owl:Class;
        rdfs:label          "federal state"@en;
        rdfs:subClassOf     nfdicore:NFDI_0000005;
        skos:definition     "A place that refers to a geographical territory forming part of a country."@en;
        skos:editorialNote  "A federal state where the thing is located."@en;
        skos:example        "Sachsen, Berlin"@de .

nfdicore:NFDI_0000223
        rdf:type            owl:Class;
        rdfs:label          "website"@en;
        rdfs:subClassOf     [ rdf:type            owl:Class;
                              owl:intersectionOf  ( obo:IAO_0000030
                                                    [ rdf:type            owl:Restriction;
                                                      owl:onProperty      obo:RO_0002353;
                                                      owl:someValuesFrom  nfdicore:NFDI_0000224
                                                    ]
                                                  )
                            ];
        skos:definition     "An information content entity that represents a collection of interconnected web pages, multimedia content, and digital resources accessible via the World Wide Web."@en;
        skos:editorialNote  "A collection of webpages contributed by an organization or a person."@en;
        skos:example        "https:\\/\\/opac.rism.info" .

nfdicore:NFDI_0000123
        rdf:type            owl:Class;
        rdfs:label          "data portal"@en;
        rdfs:subClassOf     nfdicore:NFDI_0000223;
        skos:definition     "A website that serves as a centralized platform for accessing, managing, and sharing datasets, information, or resources related to a specific topic, theme, or domain."@en;
        skos:editorialNote  "An online platform that provides access to datasets."@en;
        skos:example        "Bach digital, KultSam, MusiXplora"@en .

nfdicore:NFDI_0000122
        rdf:type         owl:Class;
        rdfs:label       "data curation service"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000101;
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        skos:definition  "The activity of managing and promoting the use of data from their point of creation to ensure that they are fit for contemporary purpose and available for discovery and reuse. For dynamic datasets this may mean continuous enrichment or updating to keep them fit for purpose. Higher levels of curation will also involve links with annotation and with other published materials"@en .

nfdicore:NFDI_0000121
        rdf:type         owl:Class;
        rdfs:label       "database software"@en;
        rdfs:subClassOf  obo:IAO_0000010;
        obo:IAO_0000119  <https://doi.org/10.5281/zenodo.10101412>;
        skos:definition  "Software that provides large amounts of structured data from repositories and archives to the user. Usually the data can be uploaded, accessed, searched and/or downloaded via a web browser."@en .

nfdicore:NFDI_0000119
        rdf:type            owl:Class;
        rdfs:label          "country"@en;
        rdfs:subClassOf     nfdicore:NFDI_0000005;
        skos:definition     "A place that refers to a defined geographical area distinguished by its territorial boundaries, governance structure, and sovereignty."@en;
        skos:editorialNote  "A country where the thing is located."@en .

nfdicore:NFDI_0000115
        rdf:type               owl:Class;
        rdfs:label             "contributing process"@en;
        rdfs:subClassOf        obo:BFO_0000015;
        skos:definition        "A process of contibuting or providing information to an endeavor."@en;
        nfdicore:NFDI_0000012  "Contributing" .

nfdicore:NFDI_0000111
        rdf:type               owl:Class;
        rdfs:label             "contacting process"@en;
        rdfs:subClassOf        obo:BFO_0000015;
        skos:definition        "A process in which the contact information of an entity is provided."@en;
        nfdicore:NFDI_0000012  "Contacting" .

nfdicore:NFDI_0000106
        rdf:type            owl:Class;
        rdfs:label          "city"@en;
        rdfs:subClassOf     nfdicore:NFDI_0000005;
        skos:definition     "A place that refers to a densely populated urban area."@en;
        skos:editorialNote  "A city or a town where the thing is located."@en;
        skos:example        "Berlin, Hannover, Kyiv"@en .

nfdicore:NFDI_0000101
        rdf:type               owl:Class;
        rdfs:label             "service process"@en;
        rdfs:subClassOf        [ rdf:type            owl:Class;
                                 owl:intersectionOf  ( obo:BFO_0000015
                                                       [ rdf:type            owl:Restriction;
                                                         owl:onProperty      obo:RO_0002234;
                                                         owl:someValuesFrom  nfdicore:NFDI_0000232
                                                       ]
                                                     )
                               ];
        skos:definition        "A process that organizes activities and resources to deliver a specific service, ensuring its efficiency, reliability, and alignment with intended goals."@en;
        nfdicore:NFDI_0010013  "Issue: https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/75" .

nfdicore:NFDI_0000030
        rdf:type            owl:Class;
        rdfs:label          "source code repository"@en;
        rdfs:subClassOf     obo:IAO_0000310;
        skos:definition     "A document that organizes and stores source code files, associated metadata, and version history to facilitate the management, sharing, and collaborative development of software projects. It serves as a structured collection of information that tracks changes, maintains integrity, and supports workflows such as version control, branching, and merging.";
        skos:editorialNote  "The source code repository stands for the CONTENT of the repository, which, e.g., you can copy to your hard drive. This distinguishes it from the website class which e.g. is used to publish the content."@en .

nfdicore:NFDI_0000029
        rdf:type            owl:Class;
        rdfs:label          "obsolete report"@en;
        obo:IAO_0100001     obo:IAO_0000088;
        owl:deprecated      true;
        skos:definition     "A document that conveys information, data, or findings, typically structured in a formal or semi-formal manner, to communicate the results of an analysis, investigation, observation, or activity.";
        skos:editorialNote  "A report is created with the intent of informing specific audiences and may include textual descriptions, visualizations, metrics, or conclusions. It is a realizable entity that is produced and maintained as part of a process or workflow." .

nfdicore:NFDI_0000027
        rdf:type         owl:Class;
        rdfs:label       "file data item"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:IAO_0000027
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      nfdicore:NFDI_0000226;
                                                   owl:someValuesFrom  obo:IAO_0000098
                                                 ]
                                               )
                         ];
        skos:definition  "A file data item is a data item that represents a file stored on a hard drive. It might also include essential attributes like its name, location, download URL, size, type, and timestamps for creation, modification, and access. It might also capture permissions and ownership details to control how the file can be accessed or modified."@en .

nfdicore:NFDI_0000026
        rdf:type         owl:Class;
        rdfs:label       "ontology release version"@en;
        rdfs:subClassOf  obo:IAO_0000027;
        skos:definition  "An (nfdi) ontology release version represents a particular release of an ontology."@en .

nfdicore:NFDI_0000025
        rdf:type         owl:Class;
        rdfs:label       "patent"@en;
        rdfs:subClassOf  obo:IAO_0000310;
        obo:IAO_0000112  "US Patent 6,449,603";
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000313";
        skos:definition  "A document that has been accepted by a patent authority"@en .

nfdicore:NFDI_0000023
        rdf:type         owl:Class;
        rdfs:label       "ontology"@en;
        rdfs:subClassOf  obo:IAO_0000027;
        skos:definition  "An (nfdi) ontology is a data item that coherently represents all components of an ontology, including its versions, variants, modules and other associated artifacts. It is typically denoted by a name and/or an acronym, which is the term we use to communicate about it."@en .

nfdicore:NFDI_0000022
        rdf:type         owl:Class;
        rdfs:label       "obsolete document"@en;
        obo:IAO_0000112  "A journal article, patent application, laboratory notebook, or a book";
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000310";
        obo:IAO_0100001  obo:IAO_0000310;
        owl:deprecated   true;
        skos:definition  "A collection of information content entities intended to be understood together as a whole"@en .

nfdicore:NFDI_0001002
        rdf:type         owl:Class;
        rdfs:label       "workflow specification"@en;
        rdfs:subClassOf  obo:IAO_0000104;
        skos:definition  "A plan specification that defines the sequence, dependencies, roles, and conditions governing the execution of tasks and processes within a workflow, ensuring structured and efficient task coordination, automation, and completion." .

nfdicore:NFDI_0000227
        rdf:type         owl:Class;
        rdfs:label       "workflow process"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:BFO_0000015
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:BFO_0000055;
                                                   owl:someValuesFrom  [ rdf:type            owl:Class;
                                                                         owl:intersectionOf  ( obo:OBI_0000260
                                                                                               [ rdf:type            owl:Restriction;
                                                                                                 owl:onProperty      obo:RO_0000059;
                                                                                                 owl:someValuesFrom  nfdicore:NFDI_0001002
                                                                                               ]
                                                                                             )
                                                                       ]
                                                 ]
                                               )
                         ];
        skos:definition  "A process that processes tasks, activities, or steps to achieve specific objectives efficiently within an organized workflow system."@en .

nfdicore:NFDI_0000021
        rdf:type               owl:Class;
        rdfs:label             "obsolete workflow"@en;
        owl:deprecated         true;
        skos:definition        "A plan that specifies a sequence of tasks, processes, or operations, often involving multiple agents, tools, or systems, to achieve a specific goal or produce a desired outcome."@en;
        skos:editorialNote     "A workflow defines the logical order and dependencies of steps, the roles or entities responsible for each step, and the inputs and outputs required for and produced by each task. It is a realizable entity that can be enacted or executed within a defined context, such as a business process, computational framework, or organizational procedure.";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/125" .

nfdicore:NFDI_0000020
        rdf:type         owl:Class;
        rdfs:label       "industry organization role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000081;
                                                   owl:someValuesFrom  obo:OBI_0000245
                                                 ]
                                               )
                         ];
        skos:definition  "A role inherent in an organization that is realized when promoting, regulating, or supporting industry-specific standards, practices, and collaboration to advance sector development and innovation."@en .

nfdicore:NFDI_0000019
        rdf:type         owl:Class;
        rdfs:label       "academic organization role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000081;
                                                   owl:someValuesFrom  obo:OBI_0000245
                                                 ]
                                               )
                         ];
        skos:definition  "A role inherent in an organization that is realized when coordinating, managing, or supporting academic activities, programs, or research to promote education and knowledge advancement."@en .

nfdicore:NFDI_0000131
        rdf:type            owl:Class;
        rdfs:label          "event"@en;
        rdfs:subClassOf     obo:BFO_0000015;
        skos:definition     "An process that represents an organized happening that unfolds in time."@en;
        skos:editorialNote  "A class that represents entities that occur or unfold in time, typically characterized by a specific organized happening or occurrence with temporal properties."@en;
        skos:example        "conferences, celebrations, workshops, meetings, or any other specific incident or happening that has been planned somehow."@en .

nfdicore:NFDI_0000018
        rdf:type         owl:Class;
        rdfs:label       "academic event"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000131
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000057;
                                                   owl:someValuesFrom  [ rdf:type            owl:Restriction;
                                                                         owl:onProperty      obo:RO_0000087;
                                                                         owl:someValuesFrom  nfdicore:NFDI_0000019
                                                                       ]
                                                 ]
                                               )
                         ];
        skos:definition  "An event that focuses on scholarly activities and the exchange of knowledge, typically involving presentations, discussions, or collaborations among researchers, academics, and students, often in the context of conferences, workshops, seminars, symposia, or colloquia, to advance a specific field of study or interdisciplinary research."@en .

nfdicore:NFDI_0000017
        rdf:type         owl:Class;
        rdfs:label       "spokesperson role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000081;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000004
                                                 ]
                                               )
                         ];
        skos:definition  "A role inherent in an agent that is realized when representing, advocating, or communicating on behalf of an organization or group to convey messages or information."@en .

nfdicore:NFDI_0000016
        rdf:type         owl:Class;
        rdfs:label       "software development"@en;
        rdfs:subClassOf  obo:BFO_0000015;
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/APOLLO_SV_00000008";
        skos:definition  "A process that has specified output a software product and that involves the creation of source code."@en .

nfdicore:NFDI_0000014
        rdf:type         owl:Class;
        rdfs:label       "obsolete publishing process"@en;
        obo:IAO_0000119  "http://purl.obolibrary.org/obo/IAO_0000444";
        obo:IAO_0100001  obo:IAO_0000444;
        owl:deprecated   true;
        skos:definition  "A process of making information, such as literature, music, and software etc., available to the public for sale or for free."@en .

nfdicore:NFDI_0000011
        rdf:type         owl:Class;
        rdfs:label       "obsolete plan"@en;
        obo:IAO_0100001  obo:OBI_0000260;
        owl:deprecated   true;
        skos:definition  "A realizable entity that represents a structured set of intended actions or steps designed to achieve specific objectives or outcomes."@en .

nfdicore:NFDI_0000224
        rdf:type         owl:Class;
        rdfs:label       "creative process"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:BFO_0000015
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000057;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000004
                                                 ]
                                               )
                         ];
        skos:definition  "A process that involves generating, developing, and refining original ideas or concepts through exploration, experimentation, and problem-solving, aiming to produce innovative or expressive outcomes in artistic, scientific, or other creative fields."@en .

nfdicore:NFDI_0000110
        rdf:type             owl:Class;
        rdfs:label           "consortium member role"@en;
        rdfs:subClassOf      nfdicore:NFDI_0000229;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:onProperty      obo:BFO_0000054;
                               owl:someValuesFrom  nfdicore:NFDI_0000002
                             ];
        owl:equivalentClass  [ rdf:type            owl:Class;
                               owl:intersectionOf  ( nfdicore:NFDI_0000229
                                                     [ rdf:type            owl:Restriction;
                                                       owl:onProperty      obo:BFO_0000054;
                                                       owl:someValuesFrom  nfdicore:NFDI_0000002
                                                     ]
                                                     [ rdf:type           owl:Restriction;
                                                       owl:allValuesFrom  obo:OBI_0000245;
                                                       owl:onProperty     obo:RO_0000081
                                                     ]
                                                   )
                             ];
        skos:definition      "A role inherent in an organization that is realized when the organization is a member of a consortium."@en .

nfdicore:NFDI_0000006
        rdf:type            owl:Class;
        rdfs:label          "consortium"@en;
        rdfs:subClassOf     [ rdf:type            owl:Class;
                              owl:intersectionOf  ( obo:OBI_0000245
                                                    [ rdf:type            owl:Restriction;
                                                      owl:onProperty      obo:RO_0002351;
                                                      owl:someValuesFrom  [ rdf:type            owl:Restriction;
                                                                            owl:onProperty      obo:RO_0000087;
                                                                            owl:someValuesFrom  nfdicore:NFDI_0000110
                                                                          ]
                                                    ]
                                                  )
                            ];
        skos:definition     "An organisation that consists of multiple independent groups and individuals, who join together to collaborate on a specific goal."@en;
        skos:editorialNote  "A consortium of autonomous organizations collaborating towards a shared goal, operating within the framework of an agreement."@en;
        skos:example        "NFDI4Culture, NFDI-MatWerk, DataPLANT." .

nfdicore:NFDI_0000229
        rdf:type         owl:Class;
        rdfs:label       "agent role"@en;
        rdfs:subClassOf  [ rdf:type            owl:Class;
                           owl:intersectionOf  ( obo:BFO_0000023
                                                 [ rdf:type            owl:Restriction;
                                                   owl:onProperty      obo:RO_0000081;
                                                   owl:someValuesFrom  nfdicore:NFDI_0000102
                                                 ]
                                               )
                         ];
        skos:definition  "Role of an independent continuant that is realized through an agent's actions, enabling the agent to perform specific functions or achieve particular outcomes within a system or context."@en .

nfdicore:NFDI_0000232
        rdf:type         owl:Class;
        rdfs:label       "service product"@en;
        rdfs:subClassOf  obo:BFO_0000141;
        skos:definition  "An immaterial entity that provides value through a service offering, delivering intangible benefits or functionality designed to fulfill specific needs or requirements, often in a structured process."@en .

nfdicore:NFDI_0000008
        rdf:type               owl:Class;
        rdfs:label             "obsolete creative work"@en;
        owl:deprecated         true;
        skos:definition        "An independent continuant or information content entity that refers to a manifestation of someone's creative effort. A creative work refers to a digital intellectual or artistic resource, e.g. a dataset, metadata, a guideline, a software and other materials offering relevant information or instructions within their specific domains."@en;
        skos:editorialNote     "2024-03-22. Sasha Bruns - Unlike schema:CreativeWork, nfdicore:CreativeWork is specialized to cover digital creative works only. Through the mapping to \"schema:CreativeWork and 'information content entity'\", we exclude material creative works such as real paintings, architectural objects, and other physical artifacts, which fall outside the scope of nfdicore:CreativeWork."@en;
        skos:example           "TRANSRAZ Data Model, NFDI4Culture Knowledge Graph, Guide for digital collection management at art museums, NFDI4Culture SPARQL Endpoint, Registry for Tools & Services, RADAR4Culture service, etc.";
        nfdicore:NFDI_0010013  "https://github.com/ISE-FIZKarlsruhe/nfdicore/issues/122" .

<http://www.ebi.ac.uk/swo/SWO_0000002>
        rdf:type         owl:Class;
        rdfs:label       "software license" , "licence"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        obo:IAO_0000115  "A licence is a legal instrument (usually by way of contract law, with or without printed material) governing the use or redistribution of the resource containing the licence.";
        obo:IAO_0000119  "Modified from http://en.wikipedia.org/wiki/Software_license" .

obo:IAO_8000013  rdf:type  owl:Class;
        rdfs:label       "reasoned ontology module"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000024;
        obo:IAO_0000115  "An ontology module that contains axioms generated by a reasoner. The generated axioms are typically direct SubClassOf axioms, but other possibilities are available."@en .

obo:IAO_8000003  rdf:type  owl:Class;
        rdfs:label       "main release ontology module"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000024;
        obo:IAO_0000115  "An ontology module that is intended to be the primary release product and the one consumed by the majority of tools."@en;
        obo:IAO_0000116  "TODO: Add logical axioms that state that a main release ontology module is derived from (directly or indirectly) an editors module"@en .

obo:IAO_8000002  rdf:type  owl:Class;
        rdfs:label       "editors ontology module"@en;
        rdfs:subClassOf  obo:IAO_8000000;
        obo:IAO_0000115  "An ontology module that is intended to be directly edited, typically managed in source control, and typically not intended for direct consumption by end-users."@en;
        obo:IAO_0000118  "source ontology module"@en .

nfdicore:NFDI_0000024
        rdf:type         owl:Class;
        rdfs:label       "ontology variant"@en;
        rdfs:subClassOf  obo:IAO_8000000;
        skos:definition  "An ontology variant represents a self-contained, reusable subset of an ontology that provides a specific functionality while maintaining interoperability with the larger ontology. Typically, an ontology is released in different variants, which makes a variant a release artifact."@en .

obo:IAO_8000001  rdf:type  owl:Class;
        rdfs:label       "base ontology module"@en;
        rdfs:subClassOf  nfdicore:NFDI_0000024;
        obo:IAO_0000115  "An ontology module that comprises only of asserted axioms local to the ontology, excludes import directives, and excludes axioms or declarations from external ontologies."@en .

obo:IAO_8000000  rdf:type  owl:Class;
        rdfs:label       "ontology module"@en;
        rdfs:subClassOf  obo:IAO_0000102;
        obo:IAO_0000116  "I have placed this under 'data about an ontology part', but this can be discussed. I think this is OK if 'part' is interpreted reflexively, as an ontology module is the whole ontology rather than part of it."@en;
        obo:IAO_0000118  "ontology file"@en .

obo:IAO_0020017  rdf:type  owl:Class;
        rdfs:label       "family name"@en;
        rdfs:subClassOf  obo:IAO_0020000;
        obo:IAO_0000115  "An identifier that is typically a part of a person's name which has been passed, according to law or custom, from one or both parents to their children."@en;
        obo:IAO_0000118  "surname"@en , "last name"@en;
        obo:IAO_0000119  "http://en.wikipedia.org/wiki/Family_name" .

obo:IAO_0020016  rdf:type  owl:Class;
        rdfs:label       "given name"@en;
        rdfs:subClassOf  obo:IAO_0020015;
        obo:IAO_0000115  "A personal name that specifies and differentiates between members of a group of individuals, especially in a family, all of whose members usually share the same family name (surname). A given name is purposefully given, usually by a child's parents at or near birth, in contrast to an inherited one such as a family name"@en;
        obo:IAO_0000118  "first name"@en;
        obo:IAO_0000119  "http://en.wikipedia.org/wiki/Given_name" .

obo:IAO_0000708  rdf:type  owl:Class;
        rdfs:label       "ORCID identifier"@en;
        rdfs:subClassOf  obo:IAO_0000578;
        obo:IAO_0000115  "A centrally registered identifier that is issued by ORCID (https://orcid.org/) and used to persistantly identify oneself as a human researcher or contributor.";
        obo:IAO_0000116  "This class was originally defined in Apollo_SV (http://purl.obolibrary.org/obo/APOLLO_SV_00000496) but due to it being more in scope of IAO, it was decided to add it to IAO and deprecate its Apollo_SV equivalent. (2022-10-25)" , "\"You can connect your iD with your professional information — affiliations, grants, publications, peer review, and more. You can use your iD to share your information with other systems, ensuring you get recognition for all your contributions, saving you time and hassle, and reducing the risk of errors.\" [https://orcid.org/]";
        obo:IAO_0000118  "Open Researcher and Contributor Identifier" , "Open Researcher and Contributor ID" , "ORCiD" , "ORCID ID";
        obo:IAO_0000119  "https://orcid.org/" .

obo:IAO_0000640  rdf:type  owl:Class;
        rdfs:label       "related work textual entity"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000112  "Excerpt from Žitnik and Zupan. Bioinformatics. 2015 Jun 15; 31(12): i230–i239. (http://www.ncbi.nlm.nih.gov/pmc/articles/PMC4542780/):\n\nOur work presented here is similar in spirit to our recently developed methodology for data fusion via collective matrix factorization (Žitnik and Zupan, 2015).\n\n"@en;
        obo:IAO_0000115  "A textual entity that discusses work from other publications and expresses their relevancy to the content of a document."@en .

obo:IAO_0000608  rdf:type  owl:Class;
        rdfs:label       "author information textual entity"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000112  "From Takon. Ann Gen Psychiatry. 2011; 10: 25. (http://www.ncbi.nlm.nih.gov/pmc/articles/PMC3204268/):\n\nIT [the author] is the lead paediatrician for ADHD services in East Hertfordshire, UK, where she runs a weekly joint ADHD clinic with the Child and Adolescent psychiatrist and works within an ADHD specialist team. IT also sees children with other neurodisability issues who may have comorbid ADHD, where the presentation may be more complex and challenging to manage. IT has vast experience in managing children with complex ADHD. She has 18 years of experience in paediatrics and also has extensive experience in the use of psychopharmacologic agents in managing children with ADHD."@en;
        obo:IAO_0000115  "A textual entity expression information about an author of a document. This information may include biographical information and may discuss how the authors' professional experiences are relevant to the work described in the document."@en .

obo:IAO_0000605  rdf:type  owl:Class;
        rdfs:label       "abbreviation textual entity"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000112  "From Shiba et al. Acta Neuropathol Commun. 2013; 1: 45. (http://www.ncbi.nlm.nih.gov/pmc/articles/PMC3893467/):\n\nBAC: Bacterial artificial chromosome; CR: Calretinin; GFAP: Glial fibrillary acidic protein; MAP: Microtubule-associated protein; MRI: Magnetic resonance imaging; NSC: Neural stem cell; PDA: Patent ductus arteriosus; PMG: Polymicrogyria; PNH: Periventricular nodular heterotopia; VSD: Ventricular septal defect."@en;
        obo:IAO_0000115  "A textual entity listing abbreviations and their expansions that are used in a document."@en .

obo:IAO_0000590  rdf:type  owl:Class;
        rdfs:label       "written name"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000112  "\"United States of America\""@en , "\"The Eiffel Tower\""@en , "\"Bill Clinton\""@en;
        obo:IAO_0000115  "A textual entity that denotes a particular in reality."@en;
        obo:IAO_0000119  "https://github.com/information-artifact-ontology/IAO/issues/114"@en .

obo:IAO_0020020  rdf:type  owl:Class;
        rdfs:label       "code set"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:onProperty      obo:BFO_0000051;
                           owl:someValuesFrom  obo:IAO_0020000
                         ];
        obo:IAO_0000115  "An information content entity that is a collection of other information content entities that has been created to identify or annotate things in a specified domain, and where the intention of its creators is that the collection has a one-to-one correspondence with those things."@en;
        obo:IAO_0000118  "controlled vocabulary"@en , "coding system"@en , "codeset"@en , "code system"@en , "code map"@en .

obo:IAO_0000579  rdf:type  owl:Class;
        rdfs:label       "centrally registered identifier registry"@en;
        rdfs:subClassOf  obo:IAO_0020020;
        obo:IAO_0000112  "PubMed is a CRID registry. It has a code set of PubMed identifiers associated with journal articles. "@en;
        obo:IAO_0000115  "A code set of CRID records, each consisting of a CRID symbol and additional information which was recorded in the code set through an assigning a centrally registered identifier process."@en;
        obo:IAO_0000118  "CRID registry";
        obo:IAO_0000119  "Original proposal from Bjoern, discussions at IAO calls"@en .

nfdicore:NFDI_0000015
        rdf:type         owl:Class;
        rdfs:label       "obsolete identifier"@en;
        obo:IAO_0100001  "http://purl.obolibrary.org/obo/IAO_0020000";
        owl:deprecated   true;
        skos:definition  "An information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity." .

obo:IAO_0000577  rdf:type  owl:Class;
        rdfs:label       "centrally registered identifier symbol"@en;
        rdfs:subClassOf  obo:IAO_0000028;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:onProperty      obo:BFO_0000050;
                           owl:someValuesFrom  obo:IAO_0000578
                         ];
        obo:IAO_0000112  "The sentence \"The article has Pubmed ID 12345.\" contains a CRID that has two parts: one part is the CRID symbol, which is '12345'; the other part denotes the CRID registry, which is Pubmed."@en;
        obo:IAO_0000115  "A symbol that is part of a CRID and that is sufficient to look up a record from the CRID's registry."@en;
        obo:IAO_0000118  "CRID symbol";
        obo:IAO_0000119  "Original proposal from Bjoern, discussions at IAO calls"@en .

obo:IAO_0000429  rdf:type  owl:Class;
        rdfs:label       "email address"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        obo:IAO_0000116  "Alan Ruttenberg 1/3/2012 - Provisional id, see issue at https://github.com/information-artifact-ontology/IAO/issues/130&thanks=130&ts=1325636583"@en .

obo:IAO_0000422  rdf:type  owl:Class;
        rdfs:label       "postal address"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000115  "A textual entity that is used as directive to deliver something to a person, or organization";
        obo:IAO_0000116  "2010-05-24 Alan Ruttenberg. Use label for the string representation. See issue https://github.com/information-artifact-ontology/IAO/issues/59" .

obo:IAO_0000421  rdf:type  owl:NamedIndividual;
        rdfs:label       "named class expression"@en;
        obo:IAO_0000115  "A named class expression is a logical expression that is given a name. The name can be used in place of the expression."@en;
        obo:IAO_0000116  "named class expressions are used in order to have more concise logical definition but their extensions may not be interesting classes on their own. In languages such as OWL, with no provisions for macros, these show up as actuall classes. Tools may with to not show them as such, and to replace uses of the macros with their expansions"@en .

obo:IAO_0000420  rdf:type  owl:NamedIndividual;
        rdfs:label       "defined class"@en;
        obo:IAO_0000115  "A defined class is a class that is defined by a set of logically necessary and sufficient conditions but is not a universal"@en;
        obo:IAO_0000116  "\"definitions\", in some readings, always are given by necessary and sufficient conditions. So one must be careful (and this is difficult sometimes) to distinguish between defined classes and universal."@en .

obo:IAO_0000410  rdf:type  owl:NamedIndividual;
        rdfs:label       "universal"@en;
        obo:IAO_0000116  "Hard to give a definition for. Intuitively a \"natural kind\" rather than a collection of any old things, which a class is able to be, formally. At the meta level, universals are defined as positives, are disjoint with their siblings, have single asserted parents."@en;
        obo:IAO_0000119  "A Formal Theory of Substances, Qualities, and Universals, http://ontology.buffalo.edu/bfo/SQU.pdf"@en .

obo:IAO_0000409  rdf:type    owl:Class;
        rdfs:label           "denotator type"@en;
        rdfs:subClassOf      obo:IAO_0000102;
        obo:IAO_0000112      "The Basic Formal Ontology ontology makes a distinction between Universals and defined classes, where the formal are \"natural kinds\" and the latter arbitrary collections of entities."@en;
        obo:IAO_0000115      "A denotator type indicates how a term should be interpreted from an ontological perspective."@en;
        obo:IAO_0000119      "Barry Smith, Werner Ceusters"@en;
        owl:equivalentClass  [ rdf:type   owl:Class;
                               owl:oneOf  ( obo:IAO_0000410 obo:IAO_0000420 obo:IAO_0000421 )
                             ] .

obo:IAO_0000305  rdf:type  owl:Class;
        rdfs:label       "document title"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000112  "Textual characteristics of traditional and Open Access scientific journals are similar"@en;
        obo:IAO_0000115  "A textual entity that names a document"@en .

obo:IAO_0000308  rdf:type  owl:Class;
        rdfs:label       "figure"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        obo:IAO_0000112  "Any picture, diagram or table"@en;
        obo:IAO_0000115  "An information content entity consisting of a two dimensional arrangement of information content entities such that the arrangement itself is about something."@en .

obo:IAO_0000304  rdf:type  owl:Class;
        rdfs:label       "caption"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:onProperty      obo:IAO_0000136;
                           owl:someValuesFrom  obo:IAO_0000308
                         ];
        obo:IAO_0000112  "Figure 1: A system diagram describing the modules of the Hanalyzer.  Reading methods (green) take external sources of knowledge (blue) and extract information from them, either by parsing structured data or biomedical language processing to extract information from unstructured data.  Reading modules are responsible for tracking the provenance of all knowledge.  Reasoning methods (yellow) enrich the knowledge that results from reading by, for example, noting two genes that are annotated to the same ontology term or database entry.  All knowledge sources, read or reasoned, are assigned a reliability score, and all are combined using that score into a knowledge network (orange) that represents the integration of all sorts of relationship between a pair of genes and a combined reliability score.  A data network (also orange) is created from experimental results to be analyzed.  The reporting modules (pink) integrate the data and knowledge networks, producing visualizations that can be queried with the associated drill-down tool."@en;
        obo:IAO_0000115  "A textual entity that describes a figure"@en .

obo:IAO_0000303  rdf:type  owl:Class;
        rdfs:label       "institutional identification"@en;
        rdfs:subClassOf  obo:IAO_0000300;
        obo:IAO_0000112  "University of Colorado Denver School of Medicine"@en;
        obo:IAO_0000115  "A textual entity intended to identify a particular institution"@en .

obo:IAO_0000300  rdf:type  owl:Class;
        rdfs:label       "textual entity"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        obo:IAO_0000112  "Words, sentences, paragraphs, and the written (non-figure) parts of publications are all textual entities"@en;
        obo:IAO_0000115  "A textual entity is a part of a manifestation (FRBR sense), a generically dependent continuant whose concretizations are patterns of glyphs intended to be interpreted as words, formulas, etc."@en;
        obo:IAO_0000116  "MC, 2009-09-14 (following IAO call 2009-09-01): textual entities live at the FRBR (http://en.wikipedia.org/wiki/Functional_Requirements_for_Bibliographic_Records) manifestation level. Everything is significant: line break, pdf and html versions of same document are different textual entities."@en , "AR, (IAO call 2009-09-01): a document as a whole is not typically a textual entity, because it has pictures in it - rather there are parts of it that are textual entities. Examples: The title, paragraph 2 sentence 7, etc."@en;
        obo:IAO_0000118  "text"@en .

obo:OMO_0001000  rdf:type  owl:NamedIndividual;
        rdfs:label       "out of scope";
        obo:IAO_0000115  "The term was added to the ontology on the assumption it was in scope, but it turned out later that it was not."@en;
        obo:IAO_0000116  "This obsolesence reason should be used conservatively. Typical valid examples in disease ontologies are: unnecessary class grouping; mistaked creation of a disease associated to a phenotype."@en .

obo:IAO_0000229  rdf:type  owl:NamedIndividual;
        rdfs:label       "term split"@en;
        obo:IAO_0000115  "The term has been split into two or more new terms."@en;
        obo:IAO_0000116  "This is to be used when a term has been split in two or more new terms. An editor note should indicate the reason for the split. The deprecated term should reference the replacement terms with obo:IAO_0100001."@en .

obo:IAO_0000228  rdf:type  owl:NamedIndividual;
        rdfs:label       "term imported"@en;
        obo:IAO_0000115  "The term has been replaced by a term imported from another ontology."@en;
        obo:IAO_0000116  "This is to be used when the original term has been replaced by a term imported from an other ontology. The deprecated term should reference the imported term with obo:IAO_0100001."@en .

obo:IAO_0000227  rdf:type  owl:NamedIndividual;
        rdfs:label       "terms merged"@en;
        obo:IAO_0000115  "The term has been combined with one or more other terms to create a more encompassing (merged) term."@en;
        obo:IAO_0000116  "The deprecated term should reference the merged term with obo:IAO_0100001. The replacement term should reference the original terms as sources using obo:RO_0001000 (derives_from). An editor note should explain what were the merged terms and the reason for the merge."@en .

obo:IAO_0000226  rdf:type  owl:NamedIndividual;
        rdfs:label       "placeholder removed"@en;
        obo:IAO_0000115  "The term was created to temporarily stand in for a semantic purpose, but is no longer needed, typically due to another permanent term being defined."@en;
        obo:IAO_0000116  "This reason is appropriate for a temporary term even if no permanent term is defined; for example if the need for the term no longer exists. If a permanent (replacement) term is defined, the deprecated term should reference the replacement with IAO:0100001. If no replacement is defined, it may be appropriate to reference alternative terms with oboInOwl:consider."@en .

obo:IAO_0000103  rdf:type  owl:NamedIndividual;
        rdfs:label       "failed exploratory term"@en;
        obo:IAO_0000115  "The term was initially used in an attempt to structure part of the ontology, but in retrospect failed to do a good job."@en;
        obo:IAO_0000116  "Terms created as placeholders with the expectation of being permanent should instead be deprecated using the \"placeholder removed\" (obo:IAO_0000226) justification."@en .

obo:IAO_0000225  rdf:type    owl:Class;
        rdfs:label           "obsolescence reason specification"@en;
        rdfs:subClassOf      obo:IAO_0000102;
        obo:IAO_0000115      "The reason for which a term has been deprecated. The allowed values come from an enumerated list of predefined terms. See the specification of these instances for more detailed definitions of each enumerated value."@en;
        obo:IAO_0000116      "The creation of this class has been inspired in part by Werner Ceusters' paper, Applying evolutionary terminology auditing to the Gene Ontology."@en;
        owl:equivalentClass  [ rdf:type   owl:Class;
                               owl:oneOf  ( obo:IAO_0000103 obo:IAO_0000226 obo:IAO_0000227 obo:IAO_0000228 obo:IAO_0000229 obo:OMO_0001000 )
                             ] .

obo:IAO_0000129  rdf:type  owl:Class;
        rdfs:label       "version number"@en;
        rdfs:subClassOf  obo:IAO_0000028;
        obo:IAO_0000115  "A version number is an information content entity which is a sequence of characters borne by part of each of a class of manufactured products or its packaging and indicates its order within a set of other products having the same name."@en;
        obo:IAO_0000116  "Note: we feel that at the moment we are happy with a general version number, and that we will subclass as needed in the future. For example, see 7. genome sequence version"@en .

obo:IAO_0000102  rdf:type  owl:Class;
        rdfs:label       "data about an ontology part"@en;
        rdfs:subClassOf  obo:IAO_0000027;
        obo:IAO_0000115  "Data about an ontology part is a data item about a part of an ontology, for example a term"@en .

obo:IAO_0000428  rdf:type  owl:NamedIndividual;
        rdfs:label       "requires discussion"@en;
        obo:IAO_0000115  "A term that is metadata complete, has been reviewed, and problems have been identified that require discussion before release. Such a term requires editor note(s) to identify the outstanding issues."@en;
        obo:IAO_0000119  "group:OBI"@en .

obo:IAO_0000423  rdf:type  owl:NamedIndividual;
        rdfs:label       "to be replaced with external ontology term"@en;
        obo:IAO_0000115  "Terms with this status should eventually replaced with a term from another ontology."@en;
        obo:IAO_0000119  "group:OBI"@en .

obo:IAO_0000124  rdf:type  owl:NamedIndividual;
        rdfs:label       "uncurated"@en;
        obo:IAO_0000115  "Nothing done yet beyond assigning a unique class ID and proposing a preferred term."@en .

obo:IAO_0000123  rdf:type  owl:NamedIndividual;
        rdfs:label       "metadata incomplete"@en;
        obo:IAO_0000115  "Class is being worked on; however, the metadata (including definition) are not complete or sufficiently clear to the branch editors."@en .

obo:IAO_0000121  rdf:type  owl:NamedIndividual;
        rdfs:label       "organizational term"@en;
        obo:IAO_0000115  "The term was created to ease viewing/sorting terms for development purposes, but will not be included in a release."@en .

obo:IAO_0000002  rdf:type  owl:NamedIndividual;
        rdfs:label  "example to be eventually removed"@en .

obo:IAO_0000078  rdf:type    owl:Class;
        rdfs:label           "curation status specification"@en;
        rdfs:subClassOf      obo:IAO_0000102;
        obo:IAO_0000115      "The curation status of the term. The allowed values come from an enumerated list of predefined terms. See the specification of these instances for more detailed definitions of each enumerated value."@en;
        obo:IAO_0000116      "Better to represent curation as a process with parts and then relate labels to that process (in IAO meeting)"@en;
        obo:IAO_0000119      "OBI_0000266"@en , "GROUP:OBI:<http://purl.obolibrary.org/obo/obi>"@en;
        owl:equivalentClass  [ rdf:type   owl:Class;
                               owl:oneOf  ( obo:IAO_0000002 obo:IAO_0000120 obo:IAO_0000121 obo:IAO_0000122 obo:IAO_0000123 obo:IAO_0000124 obo:IAO_0000125 obo:IAO_0000423 obo:IAO_0000428 )
                             ] .

obo:IAO_0000028  rdf:type  owl:Class;
        rdfs:label       "symbol"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        obo:IAO_0000112  "a written proper name such as \"OBI\""@en , "a stop sign"@en , "a serial number such as \"12324X\""@en;
        obo:IAO_0000115  "An information content entity that is a mark(s) or character(s) used as a conventional representation of another entity."@en;
        obo:IAO_0000116  "2014-03-31: We would like to have a deeper analysis of 'mark' and 'sign' in the future (see https://github.com/information-artifact-ontology/IAO/issues/154)."@en , "20091104, MC: this needs work and will most probably change"@en;
        obo:IAO_0000119  "based on Oxford English Dictionary"@en .

obo:IAO_0000027  rdf:type  owl:Class;
        rdfs:label       "data entity"@en;
        rdfs:subClassOf  obo:IAO_0000030;
        obo:IAO_0000112  "Data items include counts of things, analyte concentrations, and statistical summaries."@en;
        obo:IAO_0000115  "An information content entity that is intended to be one or more truthful statement(s) about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements."@en;
        obo:IAO_0000116  "JAR: datum     -- well, this will be very tricky to define, but maybe some \ninformation-like stuff that might be put into a computer and that is \nmeant, by someone, to denote and/or to be interpreted by some \nprocess... I would include lists, tables, sentences... I think I might \ndefer to Barry, or to Brian Cantwell Smith\n\nJAR: A data item is an approximately justified approximately true approximate belief"@en , "2014-03-31: See discussion at http://odontomachus.wordpress.com/2014/03/30/aboutness-objects-propositions/" , "2009-03-16: removed datum as alternative term as datum specifically refers to singular form, and is thus not an exact synonym."@en , "2009-03-16: data item deliberatly ambiguous: we merged data set and datum to be one entity, not knowing how to define singular versus plural. So data item is more general than datum."@en , "2/2/2009 Alan and Bjoern discussing FACS run output data. This is a data item because it is about the cell population. Each element records an event and is typically further composed a set of measurment data items that record the fluorescent intensity stimulated by one of the lasers."@en;
        obo:IAO_0000118  "data"@en , "data item"@en .

obo:IAO_0000120  rdf:type  owl:NamedIndividual;
        rdfs:label       "metadata complete"@en;
        obo:IAO_0000115  "Class has all its metadata, but is either not guaranteed to be in its final location in the asserted IS_A hierarchy or refers to another class that is not complete."@en .

obo:IAO_0000104  rdf:type  owl:Class;
        rdfs:label       "plan specification"@en;
        rdfs:subClassOf  obo:IAO_0000033;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:onProperty      obo:BFO_0000051;
                           owl:someValuesFrom  obo:IAO_0000007
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:onProperty      obo:BFO_0000051;
                           owl:someValuesFrom  obo:IAO_0000005
                         ];
        obo:IAO_0000112  "PMID: 18323827.Nat Med. 2008 Mar;14(3):226.New plan proposed to help resolve conflicting medical advice."@en;
        obo:IAO_0000115  "A directive information entity with action specifications and objective specifications as parts, and that may be concretized as a realizable entity that, if realized, is realized in a process in which the bearer tries to achieve the objectives by taking the actions specified."@en;
        obo:IAO_0000116  "Alternative previous definition: a plan is a set of instructions that specify how an objective should be achieved"@en , "2022-01-16 Updated definition to that proposed by Clint Dowloand, IAO Issue 231."@en , "2014-03-31: A plan specification can have other parts, such as conditional specifications."@en , "2009-03-16: provenance: a term a plan was proposed for OBI (OBI_0000344) , edited by the PlanAndPlannedProcess branch. Original definition was \" a plan is a specification of a process that is realized by an actor to achieve the objective specified as part of the plan\". It has been subsequently moved to IAO where the objective for which the original term was defined was satisfied with the definitionof this, different, term."@en;
        obo:IAO_0000119  "OBI_0000344"@en , "OBI Plan and Planned Process branch"@en .

obo:IAO_0000025  rdf:type  owl:Class;
        rdfs:label       "programming language"@en;
        rdfs:subClassOf  obo:IAO_0000104;
        obo:IAO_0000112  "R, Perl, Java"@en;
        obo:IAO_0000115  "A language in which source code is written that is intended to be executed/run by a software interpreter. Programming languages are ways to write instructions that specify what to do, and sometimes, how to do it."@en;
        obo:IAO_0000119  "group:OBI"@en , "OBI_0000058"@en .

obo:IAO_0000007  rdf:type  owl:Class;
        rdfs:label       "action specification"@en;
        rdfs:subClassOf  obo:IAO_0000033;
        obo:IAO_0000112  "Pour the contents of flask 1 into flask 2"@en;
        obo:IAO_0000115  "A directive information entity that describes an action the bearer will take."@en;
        obo:IAO_0000119  "OBI Plan and Planned Process branch"@en .

obo:IAO_0000005  rdf:type  owl:Class;
        rdfs:label       "objective specification"@en;
        rdfs:subClassOf  obo:IAO_0000033;
        obo:IAO_0000112  "In the protocol of a ChIP assay the objective specification says to identify protein and DNA interaction."@en;
        obo:IAO_0000115  "A directive information entity that describes an intended process endpoint. When part of a plan specification the concretization is realized in a planned process in which the bearer tries to effect the world so that the process endpoint is achieved."@en;
        obo:IAO_0000116  "Answers the question, why did you do this experiment?"@en , "2014-03-31: In the example of usage (\"In the protocol of a ChIP assay the objective specification says to identify protein and DNA interaction\") there is a protocol which is the ChIP assay protocol. In addition to being concretized on paper, the protocol can be concretized as a realizable entity, such as a plan that inheres in a person. The objective specification is the part that says that some protein and DNA interactions are identified. This is a specification of a process endpoint: the boundary in the process before which they are not identified and after which they are. During the realization of the plan, the goal is to get to the point of having the interactions, and participants in the realization of the plan try to do that."@en , "2009-03-16: original definition when imported from OBI read: \"objective is an non realizable information entity which can serve as that  proper part of a plan towards which the realization of the plan is directed.\""@en;
        obo:IAO_0000118  "goal specification"@en;
        obo:IAO_0000119  "OBI_0000217"@en , "OBI Plan and Planned Process/Roles Branch"@en .

obo:BFO_0000202  rdf:type  owl:Class;
        rdfs:label       "temporal interval"@en;
        rdfs:subClassOf  obo:BFO_0000038;
        dc:identifier    "155-BFO";
        skos:definition  "(Elucidation) A temporal interval is a one-dimensional temporal region that is continuous, thus without gaps or breaks"@en;
        skos:example     "The year 2018."@en;
        skos:scopeNote   "A one-dimensional temporal region can include as parts not only temporal intervals but also temporal instants separated from other parts by gaps."@en .

obo:BFO_0000146  rdf:type  owl:Class;
        rdfs:label       "fiat surface"@en;
        rdfs:subClassOf  obo:BFO_0000140;
        dc:identifier    "033-BFO";
        skos:definition  "(Elucidation) A fiat surface is a two-dimensional continuant fiat boundary that is self-connected"@en;
        skos:example     "The surface of the Earth; the plane separating the smoking from the non-smoking zone in a restaurant"@en .

obo:BFO_0000145  rdf:type  owl:Class;
        rdfs:label       "relational quality"@en;
        rdfs:subClassOf  obo:BFO_0000019;
        dc:identifier    "057-BFO";
        skos:definition  "b is a relational quality =Def b is a quality & there exists c and d such that c and d are not identical & b specifically depends on c & b specifically depends on d"@en;
        skos:example     "A marriage bond; an instance of love; an obligation between one person and another"@en .

obo:BFO_0000147  rdf:type  owl:Class;
        rdfs:label       "fiat point"@en;
        rdfs:subClassOf  obo:BFO_0000140;
        dc:identifier    "031-BFO";
        skos:definition  "(Elucidation) A fiat point is a zero-dimensional continuant fiat boundary that consists of a single point"@en;
        skos:example     "The geographic North Pole; the quadripoint where the boundaries of Colorado, Utah, New Mexico and Arizona meet; the point of origin of some spatial coordinate system"@en .

obo:BFO_0000142  rdf:type  owl:Class;
        rdfs:label       "fiat line"@en;
        rdfs:subClassOf  obo:BFO_0000140;
        dc:identifier    "032-BFO";
        skos:definition  "(Elucidation) A fiat line is a one-dimensional continuant fiat boundary that is continuous"@en;
        skos:example     "The Equator; all geopolitical boundaries; all lines of latitude and longitude; the median sulcus of your tongue; the line separating the outer surface of the mucosa of the lower lip from the outer surface of the skin of the chin"@en .

obo:BFO_0000148  rdf:type  owl:Class;
        rdfs:label       "zero-dimensional temporal region"@en;
        rdfs:subClassOf  obo:BFO_0000008;
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  obo:BFO_0000148;
                           owl:onProperty     obo:BFO_0000121
                         ];
        dc:identifier    "102-BFO";
        skos:definition  "(Elucidation) A zero-dimensional temporal region is a temporal region that is a whole consisting of one or more separated temporal instants as parts"@en;
        skos:example     "A temporal region that is occupied by a process boundary; the moment at which a finger is detached in an industrial accident"@en .

obo:BFO_0000038  rdf:type  owl:Class;
        rdfs:label        "one-dimensional temporal region"@en;
        rdfs:subClassOf   obo:BFO_0000008;
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  obo:BFO_0000038;
                            owl:onProperty     obo:BFO_0000139
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  [ rdf:type     owl:Class;
                                                 owl:unionOf  ( obo:BFO_0000038 obo:BFO_0000148 )
                                               ];
                            owl:onProperty     obo:BFO_0000121
                          ];
        dc:identifier     "103-BFO";
        owl:disjointWith  obo:BFO_0000148;
        skos:definition   "(Elucidation) A one-dimensional temporal region is a temporal region that is a whole that has a temporal interval and zero or more temporal intervals and temporal instants as parts"@en;
        skos:example      "The temporal region during which a process occurs"@en .

obo:BFO_0000034  rdf:type  owl:Class;
        rdfs:label       "function"@en;
        rdfs:subClassOf  obo:BFO_0000016;
        obo:IAO_0000112  "the function of amylase in saliva to break down starch into sugar"@en , "the function of a heart pacemaker to regulate the beating of a heart through electricity"@en , "the function of a hammer to drive in nails"@en;
        obo:IAO_0000116  "BFO 2 Reference: In the past, we have distinguished two varieties of function, artifactual function and biological function. These are not asserted subtypes of BFO:function however, since the same function – for example: to pump, to transport – can exist both in artifacts and in biological entities. The asserted subtypes of function that would be needed in order to yield a separate monoheirarchy are not artifactual function, biological function, etc., but rather transporting function, pumping function, etc."@en;
        dc:identifier    "064-BFO";
        skos:definition  "(Elucidation) A function is a disposition that exists in virtue of its bearer's physical make-up & this physical make-up is something the bearer possesses because it came into being either through evolution (in the case of natural biological entities) or through intentional design (in the case of artefacts) in order to realize processes of a certain sort"@en;
        skos:example     "The function of a hammer to drive in nails; the function of a heart pacemaker to regulate the beating of a heart through electricity"@en .

obo:BFO_0000030  rdf:type  owl:Class;
        rdfs:label       "object"@en;
        rdfs:subClassOf  obo:BFO_0000040;
        dc:identifier    "024-BFO";
        skos:definition  "(Elucidation) An object is a material entity which manifests causal unity & is of a type instances of which are maximal relative to the sort of causal unity manifested"@en;
        skos:example     "An organism; a fish tank; a planet; a laptop; a valve; a block of marble; an ice cube"@en;
        skos:scopeNote   "A description of three primary sorts of causal unity is provided in Basic Formal Ontology 2.0. Specification and User Guide"@en .

obo:BFO_0000140  rdf:type  owl:Class;
        rdfs:label       "continuant fiat boundary"@en;
        rdfs:subClassOf  obo:BFO_0000141;
        dc:identifier    "029-BFO";
        skos:definition  "(Elucidation) A continuant fiat boundary b is an immaterial entity that is of zero, one or two dimensions & such that there is no time t when b has a spatial region as continuant part & whose location is determined in relation to some material entity"@en;
        skos:example     "As for fiat point, fiat line, fiat surface"@en .

obo:BFO_0000028  rdf:type  owl:Class;
        rdfs:label       "three-dimensional spatial region"@en;
        rdfs:subClassOf  obo:BFO_0000006;
        dc:identifier    "040-BFO";
        skos:definition  "(Elucidation) A three-dimensional spatial region is a whole consisting of a spatial volume together with zero or more spatial volumes which may have spatial regions of lower dimension as parts"@en;
        skos:example     "A cube-shaped region of space; a sphere-shaped region of space; the region of space occupied by all and only the planets in the solar system at some point in time"@en .

obo:BFO_0000027  rdf:type  owl:Class;
        rdfs:label       "object aggregate"@en;
        rdfs:subClassOf  obo:BFO_0000040;
        dc:identifier    "025-BFO";
        skos:definition  "(Elucidation) An object aggregate is a material entity consisting exactly of a plurality (≥1) of objects as member parts which together form a unit"@en;
        skos:example     "The aggregate of the musicians in a symphony orchestra and their instruments; the aggregate of bearings in a constant velocity axle joint; the nitrogen atoms in the atmosphere; a collection of cells in a blood biobank"@en;
        skos:scopeNote   "The unit can, at certain times, consist of exactly one object, for example, when a wolf litter loses all but one of its pups, but it must at some time have a plurality of member parts." , "'Exactly' means that there are no parts of the object aggregate other than its member parts." .

obo:BFO_0000024  rdf:type  owl:Class;
        rdfs:label       "fiat object part"@en;
        rdfs:subClassOf  obo:BFO_0000040;
        dc:identifier    "027-BFO";
        skos:definition  "(Elucidation) A fiat object part b is a material entity & such that if b exists then it is continuant part of some object c & demarcated from the remainder of c by one or more fiat surfaces"@en;
        skos:example     "The upper and lower lobes of the left lung; the dorsal and ventral surfaces of the body; the Western hemisphere of the Earth; the FMA:regional parts of an intact human body"@en .

obo:BFO_0000019  rdf:type  owl:Class;
        rdfs:label       "quality"@en;
        rdfs:subClassOf  obo:BFO_0000020;
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  obo:BFO_0000019;
                           owl:onProperty     obo:BFO_0000050
                         ];
        obo:IAO_0000112  "the shape of your nostril"@en , "the shape of your nose"@en , "the mass of this piece of gold."@en , "the length of the circumference of your waist"@en , "the color of a tomato"@en , "the ambient temperature of this portion of air"@en;
        dc:identifier    "055-BFO";
        skos:definition  "(Elucidation) A quality is a specifically dependent continuant that, in contrast to roles and dispositions, does not require any further process in order to be realized"@en;
        skos:example     "The colour of a tomato; the ambient temperature of this portion of air; the length of the circumference of your waist; the shape of your nose; the shape of your nostril; the mass of this piece of gold"@en .

obo:BFO_0000023  rdf:type  owl:Class;
        rdfs:label       "role"@en;
        rdfs:subClassOf  obo:BFO_0000017;
        obo:IAO_0000112  "the student role"@en , "the role of subject in a clinical trial"@en , "the role of a stone in marking a property boundary"@en , "the role of a building in serving as a military target"@en , "the role of a boundary to demarcate two neighboring administrative territories"@en , "the priest role"@en , "John’s role of husband to Mary is dependent on Mary’s role of wife to John, and both are dependent on the object aggregate comprising John and Mary as member parts joined together through the relational quality of being married."@en;
        obo:IAO_0000115  "A realizable entity  the manifestation of which brings about some result or end that is not essential to a continuant  in virtue of the kind of thing that it is but that can be served or participated in by that kind of continuant  in some kinds of natural, social or institutional contexts."@en;
        obo:IAO_0000116  "BFO 2 Reference: One major family of examples of non-rigid universals involves roles, and ontologies developed for corresponding administrative purposes may consist entirely of representatives of entities of this sort. Thus ‘professor’, defined as follows,b instance_of professor at t =Def. there is some c, c instance_of professor role & c inheres_in b at t.denotes a non-rigid universal and so also do ‘nurse’, ‘student’, ‘colonel’, ‘taxpayer’, and so forth. (These terms are all, in the jargon of philosophy, phase sortals.) By using role terms in definitions, we can create a BFO conformant treatment of such entities drawing on the fact that, while an instance of professor may be simultaneously an instance of trade union member, no instance of the type professor role is also (at any time) an instance of the type trade union member role (any more than any instance of the type color is at any time an instance of the type length).If an ontology of employment positions should be defined in terms of roles following the above pattern, this enables the ontology to do justice to the fact that individuals instantiate the corresponding universals –  professor, sergeant, nurse – only during certain phases in their lives."@en;
        dc:identifier    "061-BFO";
        skos:altLabel    "externally-grounded realizable entity"@en;
        skos:definition  "(Elucidation) A role b is a realizable entity such that b exists because there is some single bearer that is in some special physical, social, or institutional set of circumstances in which this bearer does not have to be & b is not such that, if it ceases to exist, then the physical make-up of the bearer is thereby changed"@en;
        skos:example     "The priest role; the student role; the role of subject in a clinical trial; the role of a stone in marking a property boundary; the role of a boundary to demarcate two neighbouring administrative territories; the role of a building in serving as a military target"@en .

obo:BFO_0000026  rdf:type  owl:Class;
        rdfs:label       "one-dimensional spatial region"@en;
        rdfs:subClassOf  obo:BFO_0000006;
        dc:identifier    "038-BFO";
        skos:definition  "(Elucidation) A one-dimensional spatial region is a whole consisting of a line together with zero or more lines which may have points as parts"@en;
        skos:example     "An edge of a cube-shaped portion of space; a line connecting two points; two parallel lines extended in space"@en .

obo:BFO_0000018  rdf:type  owl:Class;
        rdfs:label       "zero-dimensional spatial region"@en;
        rdfs:subClassOf  obo:BFO_0000006;
        dc:identifier    "037-BFO";
        skos:definition  "(Elucidation) A zero-dimensional spatial region is one or a collection of more than one spatially disjoint points in space"@en;
        skos:example     "The spatial region occupied at some time instant by the North Pole"@en .

obo:BFO_0000009  rdf:type  owl:Class;
        rdfs:label       "two-dimensional spatial region"@en;
        rdfs:subClassOf  obo:BFO_0000006;
        dc:identifier    "039-BFO";
        skos:definition  "(Elucidation) A two-dimensional spatial region is a spatial region that is a whole consisting of a surface together with zero or more surfaces which may have spatial regions of lower dimension as parts"@en;
        skos:example     "The surface of a sphere-shaped part of space; an infinitely thin plane in space"@en .

obo:BFO_0000141  rdf:type  owl:Class;
        rdfs:label       "immaterial entity"@en;
        rdfs:subClassOf  obo:BFO_0000004;
        dc:identifier    "028-BFO";
        skos:definition  "b is an immaterial entity =Def b is an independent continuant which is such that there is no time t when it has a material entity as continuant part"@en;
        skos:example     "As for fiat point, fiat line, fiat surface, site"@en .

edamontology:format_3956
        rdf:type         owl:Class;
        rdfs:label       "N-Quads";
        rdfs:subClassOf  edamontology:format_2376 .

edamontology:format_3749
        rdf:type         owl:Class;
        rdfs:label       "JSON-LD";
        rdfs:subClassOf  edamontology:format_2376 .

edamontology:format_3262
        rdf:type         owl:Class;
        rdfs:label       "OWL/XML";
        rdfs:subClassOf  edamontology:format_2197 .

edamontology:format_3261
        rdf:type         owl:Class;
        rdfs:label       "RDF/XML";
        rdfs:subClassOf  edamontology:format_2376 .

edamontology:format_3257
        rdf:type         owl:Class;
        rdfs:label       "Notation3";
        rdfs:subClassOf  edamontology:format_2376 .

edamontology:format_3256
        rdf:type         owl:Class;
        rdfs:label       "N-Triples";
        rdfs:subClassOf  edamontology:format_2376 .

edamontology:format_3255
        rdf:type         owl:Class;
        rdfs:label       "Turtle";
        rdfs:subClassOf  edamontology:format_2376 .

edamontology:format_3253
        rdf:type         owl:Class;
        rdfs:label       "Manchester OWL Syntax";
        rdfs:subClassOf  edamontology:format_2197 .

edamontology:format_3252
        rdf:type         owl:Class;
        rdfs:label       "OWL Functional Syntax";
        rdfs:subClassOf  edamontology:format_2197 .

