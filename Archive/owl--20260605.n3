        linkml:permissible_values  <https://ld.openmicroscopy.org/core/ShapeFontStyle#Normal> , <https://ld.openmicroscopy.org/core/ShapeFontStyle#Italic> , <https://ld.openmicroscopy.org/core/ShapeFontStyle#BoldItalic> , <https://ld.openmicroscopy.org/core/ShapeFontStyle#Bold> .

core:text  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:locked  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:the_c  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:fill_rule  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:ShapeFillRule  rdf:type       linkml:EnumDefinition , owl:Class;
        owl:unionOf                ( <https://ld.openmicroscopy.org/core/ShapeFillRule#EvenOdd> <https://ld.openmicroscopy.org/core/ShapeFillRule#NonZero> );
        linkml:permissible_values  <https://ld.openmicroscopy.org/core/ShapeFillRule#NonZero> , <https://ld.openmicroscopy.org/core/ShapeFillRule#EvenOdd> .

core:font_family  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:transform  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:AffineTransform  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "AffineTransform";
        skos:definition  "\nA matrix used to transform the shape.\n\n⎡ A00, A01, A02 ⎤ ⎢ A10, A11, A12 ⎥ ⎣ 0,   0,   1   ⎦";
        skos:inScheme    core: .

