core:Folder  rdf:type    linkml:ClassDefinition , owl:Class;
        rdfs:label       "Folder";
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:description
                         ];
        skos:definition  "\nAn element specifying a possibly heterogeneous collection of data.\n\nFolders may contain Folders so that data may be organized within a\ntree of Folders. Data may be in multiple Folders but a Folder may\nnot be in more than one other Folder.\n\nAttributes\n----------\ndescription : None | str\n    A description for the folder. [plain-text multi-line string]\nfolder_ref : list[FolderRef]\n    (The Folder FolderRefs).\nimage_ref : list[ImageRef]\n    (The Folder ImageRefs).\nroi_ref : list[ROIRef]\n    (The Folder ROIRefs).\nannotation_ref : list[AnnotationRef]\n    (The Folder AnnotationRefs).\nid : str\n    (The Folder ID).\nname : None | str\n    A name for the folder that is suitable for presentation to the user.";
        skos:inScheme    core: .

core:FilterType  rdf:type          linkml:EnumDefinition , owl:Class;
        owl:unionOf                ( <https://ld.openmicroscopy.org/core/FilterType#Dichroic> <https://ld.openmicroscopy.org/core/FilterType#LongPass> <https://ld.openmicroscopy.org/core/FilterType#ShortPass> <https://ld.openmicroscopy.org/core/FilterType#BandPass> <https://ld.openmicroscopy.org/core/FilterType#MultiPass> <https://ld.openmicroscopy.org/core/FilterType#NeutralDensity> <https://ld.openmicroscopy.org/core/FilterType#Tuneable> <https://ld.openmicroscopy.org/core/FilterType#Other> );
        linkml:permissible_values  <https://ld.openmicroscopy.org/core/FilterType#Tuneable> , <https://ld.openmicroscopy.org/core/FilterType#ShortPass> , <https://ld.openmicroscopy.org/core/FilterType#Other> , <https://ld.openmicroscopy.org/core/FilterType#NeutralDensity> , <https://ld.openmicroscopy.org/core/FilterType#MultiPass> , <https://ld.openmicroscopy.org/core/FilterType#LongPass> , <https://ld.openmicroscopy.org/core/FilterType#Dichroic> , <https://ld.openmicroscopy.org/core/FilterType#BandPass> .

