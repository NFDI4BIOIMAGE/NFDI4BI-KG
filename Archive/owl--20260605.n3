core:ImagingEnvironment
        rdf:type         owl:Class , linkml:ClassDefinition;
        rdfs:label       "ImagingEnvironment";
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:humidity
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:humidity
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:co2_percent
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:co2_percent
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:map
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:map
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:air_pressure
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:air_pressure
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:co2_percent
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:humidity
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:temperature
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:temperature
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:Map;
                           owl:onProperty     core:map
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:air_pressure
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:temperature
                         ];
        skos:definition  "\nThis describes the environment that the biological sample was in during the\nexperiment.\n\nAttributes\n----------\nmap : None | Map\n    (The ImagingEnvironment Map).\ntemperature : None | float\n    The Temperature is the define units.\ntemperature_unit : UnitsTemperature\n    The units the Temperature is in - default:Celsius[°C].\nair_pressure : None | float\n    AirPressure is the define units.\nair_pressure_unit : UnitsPressure\n    The units the AirPressure is in - default:millibars[mbar].\nhumidity : None | float\n    Humidity around the sample [units:none] A fraction, as a value from 0.0 to\n    1.0.\nco2_percent : None | float\n    Carbon Dioxide concentration around the sample [units:none] A fraction, as\n    a value from 0.0 to 1.0.";
        skos:inScheme    core: .

core:ObjectiveSettings
        rdf:type         linkml:ClassDefinition , owl:Class;
        rdfs:label       "ObjectiveSettings";
        rdfs:subClassOf  core:Settings;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:medium
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:medium
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:correction_collar
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:refractive_index
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:refractive_index
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:correction_collar
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:ObjectiveSettingsMedium;
                           owl:onProperty     core:medium
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:correction_collar
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:refractive_index
                         ];
        skos:definition  "\nThis holds the setting applied to an objective as well as a reference to the\nobjective.\n\nThe ID is the objective used in this case.\n\nAttributes\n----------\nid : str\n    (The ObjectiveSettings ID).\ncorrection_collar : None | float\n    The CorrectionCollar is normally an adjustable ring on the objective. Each\n    has an arbitrary scale on it so the values is unit-less. [units:none]\nmedium : None | ObjectiveSettings_Medium\n    A description of a Medium used for the lens. The Medium is the actual\n    immersion medium used in this case.\nrefractive_index : None | float\n    The RefractiveIndex is that of the immersion medium. This is a ratio so it\n    also unit-less. [units:none]";
        skos:inScheme    core: .

core:StageLabel  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "StageLabel";
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:z
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:x
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:y
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:x
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:y
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:x
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:y
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:z
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:z
                         ];
        skos:definition  "\nThe StageLabel is used to specify a name and position for a stage position in\nthe microscope's reference frame.\n\nAttributes\n----------\nname : str\n    (The StageLabel Name).\nx : None | float\n    The X position of the stage label. Units are set by XUnit.\nx_unit : UnitsLength\n    The units of the X stage position - default:[reference frame].\ny : None | float\n    The Y position of the stage label. Units are set by YUnit.\ny_unit : UnitsLength\n    The units of the Y stage position - default:[reference frame].\nz : None | float\n    The Z position of the stage label. Units are set by ZUnit.\nz_unit : UnitsLength\n    The units of the Z  stage position - default:[reference frame].";
        skos:inScheme    core: .

core:Instrument  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "Instrument";
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:microscope
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:microscope
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:Microscope;
                           owl:onProperty     core:microscope
                         ];
        skos:definition  "\nThis element describes the instrument used to capture the Image.\n\nIt is primarily a container for manufacturer's model and catalog\nnumbers for the Microscope, LightSource, Detector, Objective and\nFilters components. The Objective element contains the additional\nelements LensNA and Magnification. The Filters element can be\ncomposed either of separate excitation, emission filters and a\ndichroic mirror or a single filter set. Within the Image itself, a\nreference is made to this one Filter element. There may be multiple\nlight sources, detectors, objectives and filters on a microscope.\nEach of these has their own ID attribute, which can be referred to\nfrom Channel. It is understood that the light path configuration can\nbe different for each channel, but cannot be different for each\ntimepoint or each plane of an XYZ stack.";
        skos:inScheme    core: .

