core:PlateAcquisition
        rdf:type         owl:Class , linkml:ClassDefinition;
        rdfs:label       "PlateAcquisition";
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:maximum_field_count
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:maximum_field_count
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:end_time
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:end_time
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Datetime;
                           owl:onProperty     core:end_time
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:maximum_field_count
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:start_time
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Datetime;
                           owl:onProperty     core:start_time
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:start_time
                         ];
        skos:definition  "\nPlateAcquisition is used to describe a single acquisition run for a plate.\n\nThis object is used to record the set of images acquired in a single\nacquisition run. The Images for this run are linked to\nPlateAcquisition through WellSample.\n\nAttributes\n----------\ndescription : None | str\n    A description for the PlateAcquisition.\nwell_sample_ref : list[WellSampleRef]\n    (The PlateAcquisition WellSampleRefs).\nannotation_ref : list[AnnotationRef]\n    (The PlateAcquisition AnnotationRefs).\nid : str\n    (The PlateAcquisition ID).\nname : None | str\n    (The PlateAcquisition Name).\nend_time : None | datetime\n    Time when the last image of this acquisition was collected\nstart_time : None | datetime\n    Time when the first image of this acquisition was collected\nmaximum_field_count : None | int\n    The maximum number of fields (well samples) in any well in this\n    PlateAcquisition. This is only used to speed up user interaction by\n    stopping the reading of every well sample.";
        skos:inScheme    core: .

