                           owl:onProperty      core:transform
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:the_t
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:stroke_width
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:stroke_width
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:stroke_width
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:transform
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:fill_color
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:the_c
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:locked
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Boolean;
                           owl:onProperty     core:locked
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:font_size
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:stroke_color
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
