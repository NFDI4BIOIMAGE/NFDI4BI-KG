core:Binning  rdf:type             linkml:EnumDefinition , owl:Class;
        owl:unionOf                ( <https://ld.openmicroscopy.org/core/Binning#1x1> <https://ld.openmicroscopy.org/core/Binning#2x2> <https://ld.openmicroscopy.org/core/Binning#4x4> <https://ld.openmicroscopy.org/core/Binning#8x8> <https://ld.openmicroscopy.org/core/Binning#Other> );
        linkml:permissible_values  <https://ld.openmicroscopy.org/core/Binning#Other> , <https://ld.openmicroscopy.org/core/Binning#8x8> , <https://ld.openmicroscopy.org/core/Binning#4x4> , <https://ld.openmicroscopy.org/core/Binning#2x2> , <https://ld.openmicroscopy.org/core/Binning#1x1> .

