                           owl:allValuesFrom  core:FilterType;
                           owl:onProperty     core:type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:transmittance_range
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:model
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:TransmittanceRange;
                           owl:onProperty     core:transmittance_range
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:transmittance_range
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:model
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:filter_wheel
                         ];
        skos:definition  "\nA filter is either an excitation or emission filters. There should be one\nfilter element specified per wavelength in the image. The channel number\nassociated with a filter set is specified in Channel. It is based on the\nFilterSpec type, so has the required attributes Manufacturer, Model, and\nLotNumber. It may also contain a Type attribute which may be set to 'LongPass',\n'ShortPass', 'BandPass', 'MultiPass',.\n\n'Dichroic', 'NeutralDensity', 'Tuneable' or 'Other'.\nIt can be associated with an optional FilterWheel - Note: this is not the same as a FilterSet\n\nAttributes\n----------\ntransmittance_range : None | TransmittanceRange\n    (The Filter TransmittanceRange).\nannotation_ref : list[AnnotationRef]\n    (The Filter AnnotationRefs).\ntype : None | Filter_Type\n    (The Filter Type).\nfilter_wheel : None | str\n    A filter 'wheel' in OME can refer to any arrangement of filters in a filter\n    holder of any shape. It could, for example, be a filter slider. [plain text\n    string]\nid : str\n    (The Filter ID).";
        skos:inScheme    core: .

