        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:description
                         ];
        skos:definition  "\nAn abstract Basic Annotation from which some others are derived.";
        skos:inScheme    core: .

core:namespace  rdf:type  linkml:SlotDefinition , owl:ObjectProperty .

core:Experimenter  rdf:type  owl:Class , linkml:ClassDefinition;
        rdfs:label       "Experimenter";
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:middle_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:email
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:email
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:institution
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:first_name
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:institution
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:last_name
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:middle_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:middle_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:user_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:first_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:last_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:last_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:user_name
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:institution
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:user_name
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:first_name
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:email
                         ];
        skos:definition  "\nThis element describes a person who performed an imaging experiment.\n\nThis person may also be a user of the OME system, in which case the\nUserName element contains their login name. Experimenters may belong\nto one or more groups which are specified using one or more\nExperimenterGroupRef elements.\n\nAttributes\n----------\nannotation_ref : list[AnnotationRef]\n    (The Experimenter AnnotationRefs).\nid : str\n    (The Experimenter ID).\nfirst_name : None | str\n    First name, sometime called christian name or given name or forename.\n    [plain text string]\nmiddle_name : None | str\n    Any other names. [plain text string]\nlast_name : None | str\n    A person's last name sometimes called surname or family name. [plain text\n    string]\nemail : None | str\n    A person's email address. [valid email address as string]\ninstitution : None | str\n    A person's Institution The organizing structure that people belong to other\n    than groups.  A university, or company, etc. We do not specify a department\n    element, and do not mean for Institution to be used in this way. We simply\n    wish to say XXX at YYY.  Where YYY has a better chance of being tied to a\n    geographically fixed location and of being more recognizable than a group\n    of experimenters. [plain text string]\nuser_name : None | str\n    This is the username of the experimenter (in a 'unix' or 'database' sense).\n    [plain text string]";
        skos:inScheme    core: .

