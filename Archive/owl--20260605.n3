<https://nfdi.fiz-karlsruhe.de/ontology>
        rdf:type                    owl:Ontology;
        rdfs:label                  "NFDIcore";
        dct:bibliographicCitation   "Jörg Waitelonis, Oleksandra Bruns, Tabea Tietz, Dilek Yargan, Etienne Posthumus, Hossein Beygi Nasrabadi, Harald Sack. NFDIcore Ontology. Revision: v3.0.5. Retrieved from: https://nfdi.fiz-karlsruhe.de/ontology/3.0.5";
        dct:created                 "2026-04-30";
        dct:creator                 orcid:0000-0001-7192-7143 , orcid:0000-0002-3092-0532 , orcid:0000-0001-7069-9804 , orcid:0000-0001-9618-6740 , orcid:0000-0002-0006-7542 , orcid:0000-0002-1648-1684 , orcid:0000-0002-8501-6700;
        dct:description             "The National Research Data Infrastructure (NFDI) initiative has led to the formation of various consortia, each focused on developing a research data infrastructure tailored to its specific domain. To ensure interoperability across these consortia, the NFDIcore ontology has been developed as a mid-level ontology for representing metadata related to NFDI resources, including individuals, organizations, projects, data portals, and more.\nFurther infomration can be found at GitHub: https://github.com/ISE-FIZKarlsruhe/nfdicore/"@en;
        dct:license                 <https://creativecommons.org/publicdomain/zero/1.0/>;
        dct:title                   "NFDIcore Ontology"@en;
        bibo:status                 "Ontology Specification"@en;
        vann:preferredNamespaceUri  nfdicore:;
        doap:repository             <https://github.com/ISE-FIZKarlsruhe/nfdicore/>;
        owl:priorVersion            nfdicore:3.0.4;
        owl:versionIRI              nfdicore:3.0.5;
        owl:versionInfo             "3.0.5" .

