                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:fill_color
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:text
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:stroke_dash_array
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:text
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:fill_rule
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:the_z
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:font_family
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:the_z
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:fill_rule
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:locked
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:the_c
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:font_family
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:the_t
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:text
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:font_size
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:stroke_dash_array
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:the_t
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:font_size
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:stroke_dash_array
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:stroke_color
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:the_z
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:ShapeFillRule;
                           owl:onProperty     core:fill_rule
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:the_c
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:font_style
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:stroke_color
                         ];
        skos:definition  "\nThe shape element contains a single specific ROI shape and links that to any\nchannels, and a timepoint and a z-section.\n\nIt also records any transform applied to the ROI shape.\n\nAttributes\n----------\ntransform : None | AffineTransform\n    This is a matrix used to transform the shape. The element has 6 xsd:float\n    attributes. If the element is present then all 6 values must be included.\nannotation_ref : list[AnnotationRef]\n    (The Shape AnnotationRefs).\nfill_color : None | Color\n    The color of the fill - encoded as RGBA The value \"-1\" is #FFFFFFFF so\n    solid white (it is a signed 32 bit value) NOTE: Prior to the 2012-06 schema\n    the default value was incorrect and produced a transparent red not solid\n    white.\nfill_rule : None | Shape_FillRule\n    The rule used to decide which parts of the shape to fill. [enumeration]\nstroke_color : None | Color\n    The color of the stroke  - encoded as RGBA The value \"-1\" is #FFFFFFFF so\n    solid white (it is a signed 32 bit value) NOTE: Prior to the 2012-06 schema\n    the default value was incorrect and produced a transparent red not solid\n    white.\nstroke_width : None | float\n    The width of the stroke. Units are set by StrokeWidthUnit.\nstroke_width_unit : UnitsLength\n    The units used for the stroke width.\nstroke_dash_array : None | str\n    e.g. \"none\", \"10 20 30 10\"\ntext : None | str\n    (The Shape Text).\nfont_family : None | Shape_FontFamily\n    The font family used to draw the text. [enumeration] Note: these values are\n    all lower case so they match the standard HTML/CSS values. \"fantasy\" has\n    been included for completeness; we do not recommend its regular use. This\n    attribute is under consideration for removal from the OME-XML schema.\nfont_size : None | int\n    Size of the font. Units are set by FontSizeUnit.\nfont_size_unit : UnitsLength\n    The units used for the font size.\nfont_style : None | Shape_FontStyle\n    The style and weight applied to the text.  [enumeration] This is a\n    simplified combination of the HTML/CSS attributes font-style AND font-\n    weight.\nlocked : None | bool\n    Controls whether the shape is locked and read only, true is locked, false\n    is editable.\nid : str\n    (The Shape ID).\nthe_z : None | int\n    The z-section the ROI applies to. If not specified then the ROI applies to\n    all the z-sections of the image. [units:none] This is numbered from 0.\nthe_t : None | int\n    The timepoint the ROI applies to. If not specified then the ROI applies to\n    all the timepoints of the image. [units:none] This is numbered from 0.\nthe_c : None | int\n    The channel the ROI applies to. If not specified then the ROI applies to\n    all the channels of the image. [units:none] This is numbered from 0.";
        skos:inScheme    core: .

core:ShapeFontFamily  rdf:type     linkml:EnumDefinition , owl:Class;
        owl:unionOf                ( <https://ld.openmicroscopy.org/core/ShapeFontFamily#serif> <https://ld.openmicroscopy.org/core/ShapeFontFamily#sans-serif> <https://ld.openmicroscopy.org/core/ShapeFontFamily#cursive> <https://ld.openmicroscopy.org/core/ShapeFontFamily#fantasy> <https://ld.openmicroscopy.org/core/ShapeFontFamily#monospace> );
        linkml:permissible_values  <https://ld.openmicroscopy.org/core/ShapeFontFamily#serif> , <https://ld.openmicroscopy.org/core/ShapeFontFamily#sans-serif> , <https://ld.openmicroscopy.org/core/ShapeFontFamily#monospace> , <https://ld.openmicroscopy.org/core/ShapeFontFamily#fantasy> , <https://ld.openmicroscopy.org/core/ShapeFontFamily#cursive> .

