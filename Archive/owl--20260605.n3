core:DetectorSettings
        rdf:type         owl:Class , linkml:ClassDefinition;
        rdfs:label       "DetectorSettings";
        rdfs:subClassOf  core:Settings;
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:offset
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:zoom
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:zoom
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:offset
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:read_out_rate
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:offset
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:gain
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:gain
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:read_out_rate
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:integration
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:voltage
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:read_out_rate
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:integration
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:zoom
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:gain
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:Binning;
                           owl:onProperty     core:binning
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:binning
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:voltage
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:voltage
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:integration
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:binning
                         ];
        skos:definition  "\nThis holds the setting applied to a detector as well as a reference to the\ndetector.\n\nThe ID is the detector used in this case. The values stored in\nDetectorSettings represent the variable values, fixed values not\nmodified during the acquisition go in Detector. Each attribute now\nhas an indication of what type of detector it applies to. This is\npreparatory work for cleaning up and possibly splitting this object\ninto sub-types.\n\nAttributes\n----------\nid : str\n    (The DetectorSettings ID).\noffset : None | float\n    The Offset of the detector. [units none] {used:CCD,EMCCD}\ngain : None | float\n    The Gain of the detector. [units:none] {used:CCD,EMCCD,PMT}\nvoltage : None | float\n    The Voltage of the detector. {used:PMT} Units are set by VoltageUnit.\nvoltage_unit : UnitsElectricPotential\n    The units of the Voltage of the detector - default:volts[V]\nzoom : None | float\n    The Zoom or \"Confocal Zoom\" or \"Scan Zoom\" for a detector. [units:none]\n    {used:PMT}\nread_out_rate : None | float\n    The speed at which the detector can count pixels.  {used:CCD,EMCCD} This is\n    the bytes per second that can be read from the detector (like a baud rate).\n    Units are set by ReadOutRateUnit.\nread_out_rate_unit : UnitsFrequency\n    The units of the ReadOutRate - default:megahertz[Hz].\nbinning : None | Binning\n    Represents the number of pixels that are combined to form larger pixels.\n    {used:CCD,EMCCD}\nintegration : None | int\n    This is the number of sequential frames that get averaged, to improve the\n    signal-to-noise ratio. [units:none] {used:CCD,EMCCD}";
        skos:inScheme    core: .

