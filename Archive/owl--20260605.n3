core:ChannelAcquisitionMode
        rdf:type                   owl:Class , linkml:EnumDefinition;
        owl:unionOf                ( <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#WideField> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#LaserScanningConfocalMicroscopy> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SpinningDiskConfocal> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SlitScanConfocal> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#MultiPhotonMicroscopy> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#StructuredIllumination> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SingleMoleculeImaging> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#TotalInternalReflection> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#FluorescenceLifetime> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SpectralImaging> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#FluorescenceCorrelationSpectroscopy> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#NearFieldScanningOpticalMicroscopy> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SecondHarmonicGenerationImaging> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#PALM> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#STORM> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#STED> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#TIRF> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#FSM> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#LCM> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#Other> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#BrightField> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SweptFieldConfocal> <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SPIM> );
        linkml:permissible_values  <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#WideField> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#TotalInternalReflection> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#TIRF> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SweptFieldConfocal> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#StructuredIllumination> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SpinningDiskConfocal> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SpectralImaging> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SlitScanConfocal> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SingleMoleculeImaging> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SecondHarmonicGenerationImaging> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#BrightField> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#FSM> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#FluorescenceCorrelationSpectroscopy> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#FluorescenceLifetime> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#LCM> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#LaserScanningConfocalMicroscopy> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#MultiPhotonMicroscopy> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#NearFieldScanningOpticalMicroscopy> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#Other> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#PALM> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#SPIM> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#STED> , <https://ld.openmicroscopy.org/core/ChannelAcquisitionMode#STORM> .

