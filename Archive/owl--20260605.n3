        skos:definition  "\nThe dichromatic beamsplitter or dichroic mirror used for this filter\ncombination.";
        skos:inScheme    core: .

core:Experiment  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "Experiment";
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:experimenter
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:Experimenter;
                           owl:onProperty     core:experimenter
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:experimenter
                         ];
        skos:definition  "\nThis element describes the type of experiment.\n\nThe required Type attribute must contain one or more entries from the following list:\nFP FRET Time-lapse 4-D+ Screen Immunocytochemistry FISH Electrophysiology  Ion-Imaging Colocalization PGI/Documentation\nFRAP Photoablation Optical-Trapping Photoactivation Fluorescence-Lifetime Spectral-Imaging Other\nFP refers to fluorescent proteins, PGI/Documentation is not a 'data' image.\nThe optional Description element may contain free text to further describe the experiment.\n\nAttributes\n----------\ndescription : None | str\n    A description for the experiment. [plain-text multi-line string]\nexperimenter_ref : None | ExperimenterRef\n    This is a link to the Experimenter who conducted the experiment\nmicrobeam_manipulation : list[MicrobeamManipulation]\n    (The Experiment MicrobeamManipulations).\ntype : list[Experiment_value]\n    A term to describe the type of experiment.\nid : str\n    (The Experiment ID).";
        skos:inScheme    core: .

core:Settings  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "Settings";
        rdfs:subClassOf  core:Reference;
        skos:definition  "\nSettings is an empty complex type that is contained and extended by all the\n*Settings elements Each *Settings element defines an attribute named ID of\nsimple type *ID and the other information that is needed.\n\nEach simple type *ID is restricted to the base type LSID with an\nappropriate pattern";
        skos:inScheme    core: .

core:binning  rdf:type  linkml:SlotDefinition , owl:ObjectProperty;
