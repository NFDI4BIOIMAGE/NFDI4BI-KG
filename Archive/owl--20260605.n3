                           owl:onProperty      core:annotator
                         ];
        skos:definition  "\nAn annotation from which all others are ultimately derived.\n\nAttributes\n----------\ndescription : None | str\n    A description for the annotation. [plain-text multi-line string]\nannotation_ref : list[AnnotationRef]\n    (The Annotation AnnotationRefs).\nid : str\n    (The Annotation ID).\nnamespace : None | str\n    We recommend the inclusion of a namespace for annotations you define. If it\n    is absent then we assume the annotation is to use our (OME's) default\n    interpretation for this type.\nannotator : None | str\n    The Annotator is the person who attached this annotation. e.g. If UserA\n    annotates something with TagB, owned by UserB, UserA is still the\n    Annotator.";
        skos:inScheme    core: .

core:ListAnnotation  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "ListAnnotation";
        rdfs:subClassOf  core:Annotation;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:namespace
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:Experimenter;
                           owl:onProperty     core:annotator
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:namespace
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:description
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:annotator
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:namespace
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:annotator
                         ];
        skos:definition  "\nThis annotation is a grouping object.\n\nIt uses the sequence of annotation refs from the base Annotation to\nform the list.";
        skos:inScheme    core: .

