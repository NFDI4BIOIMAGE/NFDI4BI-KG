core:bin_data  rdf:type  linkml:SlotDefinition , owl:ObjectProperty;
        rdfs:label     "bin_data";
        skos:inScheme  core: .

core:BinData  rdf:type   linkml:ClassDefinition , owl:Class;
        rdfs:label       "BinData";
        skos:definition  "\nThe contents of this element are base64-encoded.\n\nThese are not CDATA sections, just a base64 stream.\n\nAttributes\n----------\nvalue : bytes\n    (The BinData value).\ncompression : BinData_Compression\n    Specifies the compression scheme used to encode the data.\nbig_endian : bool\n    This is true if the binary data was written in BigEndian order. This is\n    dependent on the system architecture of the machine that wrote the pixels.\n    True for essentially all modern CPUs other than Intel and Alpha. All Binary\n    data must be written in the same endian order.\nlength : int\n    Character count attribute for the BinData field. This is the length of the\n    base-64 encoded block. It allows easy skipping of the block when parsing\n    the file. [unit:bytes]";
        skos:inScheme    core: .

core:external  rdf:type  linkml:SlotDefinition , owl:ObjectProperty;
        rdfs:label     "external";
        skos:inScheme  core: .

core:External  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "External";
        skos:definition  "\nDescribes a file location.\n\nCan optionally specify a portion of a file using Offset and a\nReadLength. If Offset and ReadLength are specified in conjuction\nwith Compression, then they point into the uncompressed file.\n\nAttributes\n----------\nhref : str\n    file location\nsha1 : bytes\n    The digest of the file specified in href.\ncompression : External_Compression\n    Specifies the compression scheme used to encode the data.";
        skos:inScheme    core: .

core:mime_type  rdf:type  linkml:SlotDefinition , owl:ObjectProperty;
        rdfs:label     "mime_type";
        skos:inScheme  core: .

core:BinaryFile  rdf:type  linkml:ClassDefinition , owl:Class;
        rdfs:label       "BinaryFile";
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:mime_type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:external
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:bin_data
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:mime_type
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:bin_data
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:external
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:BinData;
                           owl:onProperty     core:bin_data
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  core:External;
                           owl:onProperty     core:external
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:mime_type
                         ];
        skos:definition  "\nDescribes a binary file.\n\nAttributes\n----------\nexternal : None | External\n    (The BinaryFile External).\nbin_data : None | BinData\n    (The BinaryFile BinData).\nfile_name : str\n    (The BinaryFile FileName).\nsize : int\n    Size of the uncompressed file. [unit:bytes]\nmime_type : None | str\n    (The BinaryFile MIMEType).";
        skos:inScheme    core: .

core:   rdf:type         owl:Ontology;
        rdfs:label       "OME-Core-Model";
        dct:license      "https://creativecommons.org/publicdomain/zero/1.0/";
        skos:definition  "Linked data description of the OME Data Model" .

core:LightSource  rdf:type  owl:Class , linkml:ClassDefinition;
        rdfs:label       "LightSource";
        rdfs:subClassOf  core:ManufacturerSpec;
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:power
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:lot_number
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:Integer;
                           owl:onProperty     core:power
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:serial_number
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:manufacturer
                         ];
        rdfs:subClassOf  [ rdf:type           owl:Restriction;
                           owl:allValuesFrom  linkml:String;
                           owl:onProperty     core:model
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:minCardinality  0;
                           owl:onProperty      core:power
                         ];
        rdfs:subClassOf  [ rdf:type            owl:Restriction;
                           owl:maxCardinality  1;
                           owl:onProperty      core:serial_number
                         ];
        skos:definition  "\nThe lightsource for the instrument.\n\nAn instrument may have several light sources. The type of\nlightsource is specified by one of the child-elements which are\n'Laser', 'Filament', 'Arc' or 'LightEmittingDiode'. Each of the\nlight source types has its own Type attribute to further\ndifferentiate the light source (eg, Nd-YAG for Laser or Hg for Arc).\n\nAttributes\n----------\nannotation_ref : list[AnnotationRef]\n    (The LightSource AnnotationRefs).\nid : str\n    A LightSource ID must be specified for each light source, and the\n    individual light sources can be referred to by their LightSource IDs (eg\n    from Channel).\npower : None | float\n    The light-source power. Units are set by PowerUnit.\npower_unit : UnitsPower\n    The units of the Power - default:milliwatts[mW].";
        skos:inScheme    core: .

core:ArcType  rdf:type             linkml:EnumDefinition , owl:Class;
        owl:unionOf                ( <https://ld.openmicroscopy.org/core/ArcType#Hg> <https://ld.openmicroscopy.org/core/ArcType#Xe> <https://ld.openmicroscopy.org/core/ArcType#HgXe> <https://ld.openmicroscopy.org/core/ArcType#Other> );
        linkml:permissible_values  <https://ld.openmicroscopy.org/core/ArcType#Xe> , <https://ld.openmicroscopy.org/core/ArcType#Other> , <https://ld.openmicroscopy.org/core/ArcType#HgXe> , <https://ld.openmicroscopy.org/core/ArcType#Hg> .

